{
  "name": "@luke/api",
  "version": "1.10.0-dev.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node --require ./dist/instrument.js dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "db:seed": "tsx prisma/seed.ts",
    "db:bootstrap": "tsx scripts/dev-bootstrap.ts",
    "db:nav-reset": "tsx scripts/nav-reset.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@grpc/grpc-js": "^1.11.0",
    "@luke/calendar": "workspace:*",
    "@luke/core": "workspace:*",
    "@luke/nav": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-undici": "^0.29.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "@trpc/server": "^11.18.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "argon2": "^0.44.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "ldapts": "^8.1.8",
    "mssql": "^12.6.0",
    "next-auth": "5.0.0-beta.29",
    "nodemailer": "^9.0.1",
    "pdfmake": "^0.3.11",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "pino-std-serializers": "^7.0.0",
    "prisma": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mssql": "^12.3.0",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfmake": "^0.3.2",
    "@types/supertest": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "supertest": "^7.1.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
