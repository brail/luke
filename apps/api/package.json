{
  "name": "@luke/api",
  "version": "1.7.0-rc.5",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node --require ./dist/instrument.js dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "db:seed": "tsx prisma/seed.ts",
    "db:bootstrap": "tsx scripts/dev-bootstrap.ts",
    "db:nav-reset": "tsx scripts/nav-reset.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.3.0",
    "@grpc/grpc-js": "^1.11.0",
    "@luke/core": "workspace:*",
    "@luke/nav": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
    "@opentelemetry/instrumentation-fastify": "^0.38.0",
    "@opentelemetry/instrumentation-http": "^0.52.0",
    "@opentelemetry/instrumentation-undici": "^0.3.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@prisma/client": "^6.17.1",
    "@prisma/instrumentation": "^6.17.1",
    "@trpc/server": "^11.8.0",
    "@types/jsonwebtoken": "^9.0.10",
    "argon2": "^0.41.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "ldapts": "^4.2.6",
    "mssql": "^11.0.0",
    "next-auth": "5.0.0-beta.29",
    "nodemailer": "^6.9.0",
    "pdfmake": "^0.2.23",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "pino-std-serializers": "^7.0.0",
    "prisma": "^6.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/mssql": "^9.0.0",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfmake": "^0.3.2",
    "@types/supertest": "^6.0.3",
    "@vitest/ui": "^1.0.0",
    "supertest": "^7.1.4",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.0.0"
  }
}
