// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
/// RBAC role assigned to a user: admin (full access), editor (read+write), viewer (read-only).
enum Role {
  admin
  editor
  viewer
}

/// Authentication provider for an identity: LOCAL (password-based), LDAP (directory), OIDC (OpenID Connect).
enum Provider {
  LOCAL
  LDAP
  OIDC
}

/// Type of a one-time user token: RESET (password reset), VERIFY (email verification).
enum TokenType {
  RESET
  VERIFY
}

/// Notification category used to group and filter user notifications.
enum NotificationCategory {
  SYSTEM
  CALENDAR
  USER_ACTION
  WORKFLOW
}

// Models
/// Platform user. Holds identity, role, and preferences. Relations cover auth, audit, dashboard, calendar, and notifications.
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  username        String    @unique
  firstName       String    @default("")
  lastName        String    @default("")
  /// RBAC role: admin (full access), editor (read+write), viewer (read-only).
  role            Role
  /// Soft-delete flag. Inactive users cannot log in.
  isActive        Boolean   @default(true)
  /// True while a newly registered user is awaiting admin approval.
  pendingApproval Boolean   @default(false)
  locale          String    @default("it-IT")
  timezone        String    @default("Europe/Rome")
  /// Incremented on password change or forced logout to invalidate existing JWTs.
  tokenVersion    Int       @default(0)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  loginCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  /// Authentication identities (LOCAL, LDAP, OIDC) associated with this user.
  identities                        Identity[]
  /// Audit log entries where this user is the actor.
  auditLogs                         AuditLog[]
  /// One-time tokens (password reset, email verification) belonging to this user.
  tokens                            UserToken[]
  /// Per-section visibility overrides for this user.
  sectionAccess                     UserSectionAccess[]
  /// Merchandising plan rows assigned to this user.
  assignedMerchandisingRows         MerchandisingPlanRow[]
  /// Personal dashboard widget configuration (1:1).
  dashboardConfig                   DashboardConfig?
  /// Personal dashboard task list items.
  dashboardTasks                    DashboardTask[]
  /// Personal notes on calendar events.
  calendarEventNotes                CalendarEventPersonalNote[]
  /// Company team memberships.
  teamMemberships                   CompanyTeamMembership[]
  /// Calendar events made visible to this user by a grantor.
  calendarEventVisibilitiesReceived CalendarEventUserVisibility[]  @relation("CalendarEventUserVisibilityRecipient")
  /// Calendar event visibility records granted by this user to others.
  calendarEventVisibilitiesGranted  CalendarEventUserVisibility[]  @relation("CalendarEventUserVisibilityGrantor")
  /// In-app notifications for this user.
  notifications                     Notification[]
  /// Per-category notification preferences.
  notificationPreferences           NotificationPreference[]
  /// Collection layout revisions created by this user.
  collectionLayoutRevisions         CollectionLayoutRevision[]
  /// Row phase history entries recorded by this user.
  recordedRowPhaseHistory           CollectionRowPhaseHistory[]
  /// State effect executions applied by this user.
  appliedEffects                    CalendarEventEffectExecution[] @relation("EffectApplier")
  /// State effect executions rolled back by this user.
  rolledBackEffects                 CalendarEventEffectExecution[] @relation("EffectRollbacker")
  /// Vendor closure periods confirmed by this user.
  confirmedVendorClosures           VendorClosurePeriod[]          @relation("ClosureConfirmer")
  /// Edit locks currently held by this user (planning wizard sessions).
  editLocks                         EditLock[]

  @@map("users")
}

/// Authentication identity linked to a user. A user may have multiple identities (e.g. LOCAL + LDAP).
model Identity {
  id         String   @id @default(uuid())
  /// FK to User. Cascades delete: removing a user removes all their identities.
  userId     String
  /// Authentication provider: LOCAL, LDAP, or OIDC.
  provider   Provider
  /// Provider-specific subject identifier (e.g. LDAP DN, OIDC sub).
  providerId String
  /// Optional provider-specific metadata (e.g. LDAP attributes).
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  /// The user this identity belongs to.
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local password credential, present only for LOCAL provider identities.
  localCredential LocalCredential?

  @@unique([provider, providerId])
  @@map("identities")
}

/// Bcrypt password credential for a LOCAL identity. One-to-one with Identity.
model LocalCredential {
  id           String   @id @default(uuid())
  /// FK to Identity (LOCAL provider). 1:1 unique constraint enforced.
  identityId   String   @unique
  /// Bcrypt hash of the user's password. Never stored in plain text.
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  /// The LOCAL identity this credential belongs to.
  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@map("local_credentials")
}

/// Runtime configuration store (KV). All application settings live here — never in .env. Keys defined in AppConfigRegistry (@luke/core).
model AppConfig {
  id          String   @id @default(uuid())
  /// Dot-notation key (e.g. "auth.strategy", "smtp.host"). Must match an AppConfigRegistry entry.
  key         String   @unique
  /// Stored value always as string. Use z.coerce.* or JSON.parse in the application layer.
  value       String
  /// When true, value is AES-GCM encrypted at rest. Decrypted via getConfig({ decrypt: true }).
  isEncrypted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_configs")
}

/// Immutable audit trail entry. Every create/update/delete mutation must produce one record via logAudit() or withAuditLog middleware.
model AuditLog {
  id         String   @id @default(uuid())
  /// FK to User (actor). Nullable: system actions have no actor. SetNull on user deletion preserves the log.
  actorId    String? // Sostituisce userId (più chiaro)
  /// Action in SCREAMING_SNAKE_CASE (e.g. USER_CREATE, CONFIG_UPDATE).
  action     String // SCREAMING_SNAKE_CASE (es. USER_CREATE)
  /// Resource type targeted by the action (e.g. User, Config, Auth).
  targetType String // Tipo risorsa (User, Config, Auth)
  /// ID of the target resource. Null for bulk or non-entity actions.
  targetId   String? // ID risorsa target (opzionale)
  /// Outcome of the action: SUCCESS or FAILURE.
  result     String // SUCCESS o FAILURE (esplicito)
  /// Redacted supplemental data (e.g. changed fields). Secrets must never appear here.
  metadata   Json? // Dati redatti
  /// Distributed trace ID for correlating with API logs.
  traceId    String?
  /// Client IP address at the time of the action.
  ip         String? // Rinomina da ipAddress per brevità
  createdAt  DateTime @default(now()) // Rinomina da timestamp

  // Relations
  /// The user who performed the action. Null for system-initiated events.
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

/// Short-lived one-time token for password reset or email verification. Invalidated after use or expiry.
model UserToken {
  id        String    @id @default(uuid())
  /// FK to User. Cascade delete: tokens are removed when the user is deleted.
  userId    String
  /// Token purpose: RESET (password reset flow) or VERIFY (email verification flow).
  type      TokenType
  /// SHA-256 hash of the raw token. The raw token is sent to the user; only the hash is stored.
  tokenHash String
  /// Absolute expiry timestamp. Tokens past this date must be rejected.
  expiresAt DateTime
  createdAt DateTime  @default(now())

  // Relations
  /// The user this token belongs to.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, tokenHash])
  @@index([userId, type])
  @@map("user_tokens")
}

/// Tracks every file uploaded to a storage bucket. Used for orphan cleanup and deduplication.
model FileObject {
  id              String    @id @default(uuid())
  /// Storage bucket name (e.g. "uploads", "collection-row-pictures"). Must be in localStorageConfigSchema.
  bucket          String
  /// Path key within the bucket. Unique per bucket.
  key             String
  originalName    String
  /// File size in bytes.
  size            Int
  contentType     String
  /// SHA-256 checksum of file content for integrity verification.
  checksumSha256  String
  /// User ID (string) of the uploader. Soft FK — no @relation, user may be deleted.
  createdBy       String
  /// Orphan cleanup state: PENDING (awaiting confirmation), SUCCESS (cleaned up), FAILED (cleanup error).
  cleanupStatus   String    @default("PENDING") // PENDING | SUCCESS | FAILED
  /// Number of cleanup attempts made so far.
  cleanupAttempts Int       @default(0)
  lastCleanupAt   DateTime?
  /// Null until the file is linked to an entity (e.g. brand logo saved). Unconfirmed files are eligible for cleanup.
  confirmedAt     DateTime? // null = pending confirmation; set on entity link
  createdAt       DateTime  @default(now())

  @@unique([bucket, key])
  @@index([bucket, key])
  @@index([createdAt])
  @@index([createdBy])
  @@index([cleanupStatus])
  @@index([confirmedAt])
  @@map("file_objects")
}

/// Per-user override for section visibility. Takes precedence over role defaults and AppConfig in the 4-level access evaluation.
model UserSectionAccess {
  id        String   @id @default(uuid())
  /// FK to User. Cascade delete: overrides are removed when the user is deleted.
  userId    String
  /// Dot-notation section key (e.g. 'settings', 'maintenance'). Must match sectionEnum.
  section   String // 'settings' | 'maintenance'
  /// true = explicitly allow access; false = explicitly deny access.
  enabled   Boolean // true=allow, false=deny
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The user this section override applies to.
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, section])
  @@index([userId, section])
  @@map("user_section_access")
}

/// Internal brand entity. Primary grouping for collections, pricing, and calendars. May be linked to a NAV brand record.
model Brand {
  id         String    @id @default(uuid())
  /// Unique short code (max 20 chars, aligned to NAV nvarchar).
  code       String    @unique
  name       String
  /// Storage key for the brand logo in the "brand-logos" bucket. Null if no logo uploaded.
  logoKey    String?
  /// FK to NavBrand (optional). Links this brand to the NAV replica. SetNull on NAV record deletion.
  navBrandId String?   @unique
  /// NAV brand replica linked to this brand.
  navBrand   NavBrand? @relation(fields: [navBrandId], references: [navCode], onDelete: SetNull)
  /// Soft-delete flag. Inactive brands are hidden from normal listings.
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  /// Pricing parameter sets scoped to this brand.
  pricingParameterSets PricingParameterSet[]
  /// Collection layouts scoped to this brand.
  collectionLayouts    CollectionLayout[]
  /// Merchandising plans scoped to this brand.
  merchandisingPlans   MerchandisingPlan[]
  /// Season calendars scoped to this brand.
  seasonCalendars      SeasonCalendar[]
  /// Team brand scope assignments granting teams access to this brand.
  teamBrandScopes      CompanyTeamBrandScope[]

  @@index([name])
  @@index([isActive, name])
  @@map("brands")
}

/// Fashion season entity. Secondary grouping dimension alongside Brand. May be linked to a NAV season record.
model Season {
  id          String     @id @default(uuid())
  /// Unique short code (max 10 chars, aligned to NAV nvarchar).
  code        String     @unique
  /// Optional numeric year (e.g. 2026).
  year        Int?
  name        String
  /// FK to NavSeason (optional). Links this season to the NAV replica. SetNull on NAV record deletion.
  navSeasonId String?    @unique
  /// NAV season replica linked to this season.
  navSeason   NavSeason? @relation(fields: [navSeasonId], references: [navCode], onDelete: SetNull)
  /// Soft-delete flag. Inactive seasons are hidden from normal listings.
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  /// Pricing parameter sets scoped to this season.
  pricingParameterSets PricingParameterSet[]
  /// Collection layouts scoped to this season.
  collectionLayouts    CollectionLayout[]
  /// Merchandising plans scoped to this season.
  merchandisingPlans   MerchandisingPlan[]
  /// Season calendars scoped to this season.
  seasonCalendars      SeasonCalendar[]
  /// Vendor closure periods associated with this season.
  vendorClosures       VendorClosurePeriod[]

  @@map("seasons")
}

/// Personal dashboard widget layout for a user. One record per user (1:1).
model DashboardConfig {
  id        String   @id @default(cuid())
  /// FK to User. 1:1 — one config per user. Cascade delete.
  userId    String   @unique
  /// The user this dashboard config belongs to.
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// JSON blob describing widget positions and settings.
  widgets   Json
  updatedAt DateTime @updatedAt

  @@map("dashboard_configs")
}

/// Personal to-do task shown on a user's dashboard. Not shared across users.
model DashboardTask {
  id        String    @id @default(cuid())
  /// FK to User. Cascade delete.
  userId    String
  /// The user who owns this task.
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  /// True when the task has been marked as completed.
  done      Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("dashboard_tasks")
}

/// Consolidated user preferences stored as a single JSON blob. Structure: { lastBrandId?, lastSeasonId?, menuStates? }. One record per user (PK = userId).
model UserPreference {
  /// PK = userId. No separate id field — one preference record per user.
  userId    String   @id
  /// JSON blob. Structure: { lastBrandId?, lastSeasonId?, menuStates? }. Defaults to empty object.
  data      Json?    @default("{}")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("user_preferences")
}

/// Pricing parameter set for a brand+season combination. Multiple variants per pair (e.g. Pelle, Non Pelle, Tunisia). Drives the pricing calculator.
model PricingParameterSet {
  id                     String   @id @default(uuid())
  /// FK to Brand. Restrict delete — cannot delete a brand while parameter sets exist.
  brandId                String
  /// FK to Season. Restrict delete — cannot delete a season while parameter sets exist.
  seasonId               String
  /// Human-readable variant name (e.g. "Pelle", "Non Pelle", "Tunisia"). Unique within brand+season.
  name                   String // es. "Pelle", "Non Pelle", "Tunisia"
  /// ISO 3166-1 alpha-2 country of production (e.g. "CN", "IT", "TR").
  countryCode            String // es. "CN", "IT", "TR" — ISO 3166-1 alpha-2
  /// Currency for supplier purchase prices. Supported: USD, EUR, GBP, CHF, CNY.
  purchaseCurrency       String   @default("USD")
  /// Currency for retail/wholesale selling prices. Supported: USD, EUR, GBP, CHF, CNY.
  sellingCurrency        String   @default("EUR")
  qualityControlPercent  Float
  transportInsuranceCost Float
  duty                   Float
  exchangeRate           Float
  italyAccessoryCosts    Float
  tools                  Float
  retailMultiplier       Float
  optimalMargin          Float
  /// If true, this set is the default variant selected when creating a new quotation.
  isDefault              Boolean  @default(false)
  /// Display order within the brand+season pair.
  orderIndex             Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  /// The brand this parameter set belongs to.
  brand                 Brand                    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  /// The season this parameter set belongs to.
  season                Season                   @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  /// Collection row quotations using this parameter set.
  quotations            CollectionRowQuotation[]
  /// Merchandising plan rows using this parameter set.
  merchandisingPlanRows MerchandisingPlanRow[]
  /// Vendors for whom this parameter set is enabled.
  enabledForVendors     Vendor[]                 @relation("VendorEnabledParameterSets")

  @@unique([brandId, seasonId, name])
  @@index([brandId, seasonId])
  @@map("pricing_parameter_sets")
}

/// Collection Layout — unique per brand+season pair. Represents the ordered list of lines composing a seasonal collection.
model CollectionLayout {
  id               String                     @id @default(uuid())
  /// FK to Brand. Restrict delete.
  brandId          String
  /// FK to Season. Restrict delete.
  seasonId         String
  /// Total SKU budget for the entire layout.
  skuBudget        Int?
  /// JSON array of hidden column keys. Null means all columns visible.
  hiddenColumns    Json? // String[] — colonne nascoste, null = tutte visibili
  /// Genders available for rows in this layout (e.g. ["MAN","WOMAN"]).
  availableGenders String[]                   @default(["MAN", "WOMAN"])
  /// FK to CalendarEvent that triggered a lock. Null when not locked.
  lockedByEventId  String?
  /// Timestamp when the layout was locked. Null when not locked.
  lockedAt         DateTime?
  /// The brand this layout belongs to.
  brand            Brand                      @relation(fields: [brandId], references: [id], onDelete: Restrict)
  /// The season this layout belongs to.
  season           Season                     @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  /// The calendar event that locked this layout, if any.
  lockedByEvent    CalendarEvent?             @relation(fields: [lockedByEventId], references: [id], onDelete: SetNull)
  /// Ordered groups (e.g. Uomo, Donna) within this layout.
  groups           CollectionGroup[]
  /// All rows across all groups in this layout.
  rows             CollectionLayoutRow[]
  /// Formal ISO 9001 revisions of this layout.
  revisions        CollectionLayoutRevision[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@unique([brandId, seasonId])
  @@index([brandId, seasonId])
  @@index([lockedByEventId])
  @@map("collection_layouts")
}

/// Group of rows within a Collection Layout (e.g. "Collezione Uomo", "Collezione Donna", "Special Edition"). Owns its own SKU budget.
model CollectionGroup {
  id                 String                @id @default(uuid())
  /// FK to CollectionLayout. Cascade delete — removing the layout removes all groups.
  collectionLayoutId String
  /// The layout this group belongs to.
  collectionLayout   CollectionLayout      @relation(fields: [collectionLayoutId], references: [id], onDelete: Cascade)
  name               String
  /// Display order within the layout. Lower = first.
  order              Int                   @default(0)
  /// SKU budget allocated to this group (distinct from the layout-level skuBudget).
  skuBudget          Int?
  /// Rows belonging to this group, ordered by their own order field.
  rows               CollectionLayoutRow[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([collectionLayoutId])
  @@map("collection_groups")
}

/// Sync filter configuration for a NAV entity type. One record per entity. Controls which NAV No_ are included in synchronization.
model NavSyncFilter {
  id              String   @id @default(cuid())
  /// Entity type discriminator: "vendor", "brand", or "season".
  entity          String // "vendor" | "brand" | "season"
  /// Sync scope: "all" (sync everything), "whitelist" (only listed navNos), "exclude" (all except listed navNos).
  mode            String // "all" | "whitelist" | "exclude"
  /// NAV No_ values used when mode is "whitelist" or "exclude".
  navNos          String[] // rilevante solo per whitelist/exclude
  /// Whether this sync filter is currently active.
  active          Boolean  @default(true)
  note            String?
  /// Se true, lo scheduler sincronizza automaticamente questa entità
  autoSyncEnabled Boolean  @default(false)
  /// Frequenza di sync automatico in minuti (usata solo se autoSyncEnabled=true)
  intervalMinutes Int      @default(30)
  updatedAt       DateTime @updatedAt

  @@unique([entity])
  @@index([entity, active])
  @@map("nav_sync_filters")
}

/// Read-only replica of [COMPANY$Vendor] from Microsoft NAV. NAV timestamp used only in differential sync queries — not mapped here.
model NavVendor {
  navNo      String  @id // No_
  name       String // Name
  name2      String? // Name 2
  searchName String? // Search Name
  firstName  String? // First Name
  lastName   String? // Last Name

  address     String? // Address
  address2    String? // Address 2
  postCode    String? // Post Code
  city        String? // City
  county      String? // County
  countryCode String? // Country_Region Code

  phoneNo  String? // Phone No_
  faxNo    String? // Fax No_
  email    String? // E-Mail
  homePage String? // Home Page
  contact  String? // Contact

  vendorType String? // Vendor Type

  navLastModified DateTime? // Last Date Modified
  /// Timestamp of the last successful sync from NAV.
  syncedAt        DateTime // timestamp ultimo sync

  /// Internal Vendor record linked to this NAV vendor, if matched.
  vendor Vendor? // collegamento all'anagrafica interna

  @@index([name])
  @@index([syncedAt])
  @@index([navLastModified])
  @@map("nav_vendors")
}

/// Read-only replica of [COMPANY$Brand] from Microsoft NAV.
model NavBrand {
  navCode     String   @id // Code (PK)
  description String   @default("") // Description
  /// Timestamp of the last successful sync from NAV.
  syncedAt    DateTime // timestamp ultimo sync

  /// Internal Brand record linked to this NAV brand, if matched.
  brand Brand? // collegamento all'anagrafica interna

  @@index([description])
  @@map("nav_brands")
}

/// Read-only replica of [COMPANY$Season] from Microsoft NAV.
model NavSeason {
  navCode      String    @id // Code (PK)
  description  String    @default("") // Description
  startingDate DateTime? // Starting Date
  endingDate   DateTime? // Ending Date
  /// Timestamp of the last successful sync from NAV.
  syncedAt     DateTime // timestamp ultimo sync

  /// Internal Season record linked to this NAV season, if matched.
  season Season? // collegamento all'anagrafica interna

  @@index([description])
  @@map("nav_seasons")
}

/// Internal supplier (vendor) entity. Standalone — can exist independently of NAV. Optionally linked to a NAV vendor record.
model Vendor {
  id          String     @id @default(uuid())
  name        String
  countryCode String?
  /// Short nickname used in UI listings.
  nickname    String?
  /// Name of the primary contact person at the vendor.
  referente   String?
  email       String?
  phone       String?
  /// Messaging/chat contact (e.g. WhatsApp, WeChat).
  chat        String?
  notes       String?
  /// FK to NavVendor (optional). SetNull on NAV record deletion.
  navVendorId String?    @unique
  /// NAV vendor replica linked to this vendor, if matched.
  navVendor   NavVendor? @relation(fields: [navVendorId], references: [navNo], onDelete: SetNull)
  /// Soft-delete flag. Inactive vendors are hidden from normal listings.
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  /// Collection layout rows assigned to this vendor.
  collectionRows       CollectionLayoutRow[]
  /// Pricing parameter sets for which this vendor is enabled.
  enabledParameterSets PricingParameterSet[] @relation("VendorEnabledParameterSets")
  /// Closure and open-period overrides for this vendor.
  closurePeriods       VendorClosurePeriod[]

  @@index([name])
  @@index([isActive])
  @@map("vendors")
}

/// Single row in a Collection Layout representing one line/style within a seasonal collection.
model CollectionLayoutRow {
  id                 String           @id @default(uuid())
  /// FK to CollectionLayout. Cascade delete.
  collectionLayoutId String
  /// The layout this row belongs to.
  collectionLayout   CollectionLayout @relation(fields: [collectionLayoutId], references: [id], onDelete: Cascade)
  /// FK to CollectionGroup. Cascade delete — removing a group removes all its rows.
  groupId            String
  /// The group this row belongs to.
  group              CollectionGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  /// FK to PlanningGroup. Restrict delete — a planning group can't be deleted while it still has rows.
  planningGroupId    String
  /// The planning group this row belongs to — determines which calendar events apply to it.
  planningGroup      PlanningGroup    @relation(fields: [planningGroupId], references: [id], onDelete: Restrict)
  /// Display order within the group. Lower = first.
  order              Int              @default(0)

  // Required fields
  /// Gender for this row. Validated against layout.availableGenders (MAN | WOMAN).
  gender          String // validated against layout.availableGenders
  /// FK to Vendor (optional). SetNull if vendor is deleted.
  vendorId        String?
  /// Vendor assigned to produce this row, if any.
  vendor          Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  line            String
  /// Short free-text article description appearing after the line name.
  article         String? // testo libero corto, dopo line
  /// Workflow status value from the lineStatus catalog (catalog-managed).
  status          String // catalog-managed (lineStatus)
  /// Planned SKU count (distinct sizes/colors). Belongs to Row (not Group).
  skuForecast     Int?
  qtyForecast     Int?
  productCategory String

  // Optional — identification/progress
  /// Strategy value from the strategy catalog (CORE | INNOVATION).
  strategy         String? // catalog-managed
  /// Style status value from the styleStatus catalog (catalog-managed).
  styleStatus      String? // catalog-managed
  /// FK to Phase (optional). Restrict delete — never silently lose production state if a Phase is removed.
  phaseId          String?
  /// Current production phase of this row.
  phase            Phase?  @relation(fields: [phaseId], references: [id], onDelete: Restrict)
  /// Price positioning value from the catalog (catalog-managed).
  pricePositioning String? // catalog-managed
  designer         String?
  /// Storage key for the row photo in the "collection-row-pictures" bucket.
  pictureKey       String?

  // Optional — notes
  styleNotes    String?
  materialNotes String?
  colorNotes    String?
  toolingNotes  String?

  // Optional — pricing
  /// Tooling/mold cost quoted for this row (in purchaseCurrency of the active parameter set).
  toolingQuotation Float?
  /// Pricing quotations for this row, one per parameter set variant.
  quotations       CollectionRowQuotation[]
  /// Full history of phase transitions for this row.
  phaseHistory     CollectionRowPhaseHistory[]

  /// Timestamp of the last revision snapshot that included this row.
  lastRevisedAt DateTime? // updated when row is included in a revision

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collectionLayoutId])
  @@index([groupId])
  @@index([planningGroupId])
  @@index([vendorId])
  @@index([phaseId])
  @@map("collection_layout_rows")
}

/// Pricing quotation for a collection row. A row can have N quotations with different parameter sets (e.g. CN/USD vs IT/EUR).
model CollectionRowQuotation {
  id                    String               @id @default(uuid())
  /// FK to CollectionLayoutRow. Cascade delete.
  rowId                 String
  /// The row this quotation belongs to.
  row                   CollectionLayoutRow  @relation(fields: [rowId], references: [id], onDelete: Cascade)
  /// Display order within the row's quotation list.
  order                 Int                  @default(0)
  /// FK to PricingParameterSet (optional). SetNull if the parameter set is deleted.
  pricingParameterSetId String?
  /// The pricing parameter set used for this quotation.
  pricingParameterSet   PricingParameterSet? @relation(fields: [pricingParameterSetId], references: [id], onDelete: SetNull)
  retailPrice           Float?
  /// FOB price in the purchaseCurrency defined by the linked parameter set.
  supplierQuotation     Float? // FOB in purchaseCurrency del param set
  notes                 String?
  /// SKU count specific to this quotation variant.
  sku                   Int?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([rowId])
  @@index([pricingParameterSetId])
  @@map("collection_row_quotations")
}

/// Full history of phase transitions for a collection row — distinct from AuditLog, queried directly
/// for plan-vs-actual KPIs (Fase 5/6). No unique on (rowId, phaseId): a row can regress or re-advance
/// through phases, and every transition is recorded, not just the latest.
model CollectionRowPhaseHistory {
  id               String              @id @default(uuid())
  /// FK to CollectionLayoutRow. Cascade delete — history is meaningless once the row is gone.
  rowId            String
  /// The row this history entry belongs to.
  row              CollectionLayoutRow @relation(fields: [rowId], references: [id], onDelete: Cascade)
  /// FK to Phase. Restrict delete — never silently lose historical data if a Phase is removed.
  phaseId          String
  /// The phase reached at reachedAt.
  phase            Phase               @relation(fields: [phaseId], references: [id], onDelete: Restrict)
  /// Timestamp when the row transitioned into this phase.
  reachedAt        DateTime
  /// FK to User who made the change, if known. SetNull if the user is deleted.
  recordedByUserId String?
  /// The user who made the change, if known.
  recordedByUser   User?               @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime            @default(now())

  @@index([rowId, reachedAt])
  @@index([phaseId, reachedAt])
  @@map("collection_row_phase_history")
}

/// Configurable catalog items for collection layout dropdowns. Types: strategy, lineStatus, styleStatus, revisionType, pricePositioning.
model CollectionCatalogItem {
  id                 String   @id @default(uuid())
  /// Discriminator: "strategy" | "lineStatus" | "styleStatus" | "revisionType" | "pricePositioning".
  type               String // "strategy" | "lineStatus" | "styleStatus" | "revisionType" | "pricePositioning"
  /// Immutable machine key (e.g. "CORE", "NEW"). Used as stored value in row fields.
  value              String
  /// Human-readable display label (editable).
  label              String
  /// Unused since the progress domain moved to the Phase catalog. No remaining type writes this field.
  code               String?
  /// ISO 9001 categories associated with this item. Populated only for type=revisionType.
  iso9001Categories  String[] @default([]) // categorie ISO 9001 — popolato solo per type=revisionType
  /// FK to Phase (optional). Minimum expected phase for this revision type. Populated only for type=revisionType.
  expectedMinPhaseId String?
  /// Minimum expected phase for this revision type.
  expectedMinPhase   Phase?   @relation(fields: [expectedMinPhaseId], references: [id], onDelete: Restrict)
  /// Display order within the type group.
  order              Int      @default(0)
  /// Soft-delete flag. Inactive items are hidden from pickers.
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([type, value])
  @@index([type, isActive])
  @@index([expectedMinPhaseId])
  @@map("collection_catalog_items")
}

// ─── Collection Layout Versioning ────────────────────────────────────────────

/// Formal ISO 9001:2015 revision of a Collection Layout. Immutable after creation — snapshot fields must never be updated.
model CollectionLayoutRevision {
  id                 String           @id @default(uuid())
  /// FK to CollectionLayout. Restrict delete — layout cannot be deleted while revisions exist.
  collectionLayoutId String
  /// The layout this revision belongs to.
  collectionLayout   CollectionLayout @relation(fields: [collectionLayoutId], references: [id], onDelete: Restrict)
  /// Sequential revision number within the layout (1, 2, 3…). Unique per layout.
  revisionNumber     Int
  /// Value from the revisionType catalog (e.g. "DESIGN_CHANGE").
  revisionTypeValue  String
  /// Trigger for this revision: MANUAL (user-initiated) or MILESTONE (calendar event).
  cause              String // MANUAL | MILESTONE
  /// Soft FK to the CalendarEvent milestone that triggered this revision. No @relation — event may be deleted.
  milestoneId        String?
  notes              String?
  /// FK to User who created the revision. Restrict delete.
  createdByUserId    String
  /// The user who created this revision.
  createdBy          User             @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt          DateTime         @default(now())

  /// Snapshot of all groups at the time of this revision.
  groups       CollectionGroupRevision[]
  /// Snapshot of all rows at the time of this revision.
  rowRevisions CollectionLayoutRowRevision[]

  @@unique([collectionLayoutId, revisionNumber])
  @@index([collectionLayoutId, createdAt])
  @@index([milestoneId])
  @@map("collection_layout_revisions")
}

/// Snapshot of a CollectionGroup at the time of a revision. sourceGroupId is a soft FK — the live group may have been deleted.
model CollectionGroupRevision {
  id            String                   @id @default(uuid())
  /// FK to CollectionLayoutRevision. Cascade delete.
  revisionId    String
  /// The revision this group snapshot belongs to.
  revision      CollectionLayoutRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  /// Soft FK to the live CollectionGroup at revision time. No @relation — group may be deleted post-revision.
  sourceGroupId String
  name          String
  order         Int
  skuBudget     Int?

  /// Row snapshots belonging to this group snapshot.
  rows CollectionLayoutRowRevision[]

  @@index([revisionId])
  @@index([sourceGroupId])
  @@map("collection_group_revisions")
}

/// Snapshot of a CollectionLayoutRow at the time of a revision. sourceRowId is a soft FK. wasDeleted=true means the row was already deleted when included in the revision.
model CollectionLayoutRowRevision {
  id                    String                   @id @default(uuid())
  /// FK to CollectionLayoutRevision. Cascade delete.
  revisionId            String
  /// The revision this row snapshot belongs to.
  revision              CollectionLayoutRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  /// FK to CollectionGroupRevision. Cascade delete.
  sourceGroupRevisionId String
  /// The group snapshot this row snapshot belongs to.
  sourceGroupRevision   CollectionGroupRevision  @relation(fields: [sourceGroupRevisionId], references: [id], onDelete: Cascade)
  /// Soft FK to the live CollectionLayoutRow at revision time. No @relation — row may be deleted post-revision.
  sourceRowId           String
  /// True if the row had already been soft-deleted at the time of the revision.
  wasDeleted            Boolean                  @default(false)

  // Snapshot fields — denormalised from the live row at revision time
  gender           String
  vendorId         String?
  /// Denormalised vendor name at revision time (vendor may be renamed or deleted later).
  vendorName       String?
  line             String
  article          String?
  status           String
  skuForecast      Int?
  qtyForecast      Int?
  productCategory  String
  strategy         String?
  styleStatus      String?
  progress         String?
  pricePositioning String?
  designer         String?
  /// Storage key in the immutable "collection-row-pictures-revisions" bucket.
  pictureKey       String? // key nel bucket immutabile collection-row-pictures-revisions
  styleNotes       String?
  materialNotes    String?
  colorNotes       String?
  toolingNotes     String?
  toolingQuotation Float?
  order            Int

  /// Quotation snapshots for this row at revision time.
  quotationRevisions CollectionRowQuotationRevision[]

  @@unique([revisionId, sourceRowId])
  @@index([sourceRowId, revisionId])
  @@map("collection_layout_row_revisions")
}

/// Snapshot of a CollectionRowQuotation at the time of a revision. Fully denormalised — no FK to the live quotation.
model CollectionRowQuotationRevision {
  id                      String                      @id @default(uuid())
  /// FK to CollectionLayoutRowRevision. Cascade delete.
  rowRevisionId           String
  /// The row revision this quotation snapshot belongs to.
  rowRevision             CollectionLayoutRowRevision @relation(fields: [rowRevisionId], references: [id], onDelete: Cascade)
  order                   Int
  /// Soft FK to the live PricingParameterSet. No @relation — set may be deleted post-revision.
  pricingParameterSetId   String?
  /// Denormalised parameter set name at revision time.
  pricingParameterSetName String? // denormalizzato
  retailPrice             Float?
  supplierQuotation       Float?
  notes                   String?
  sku                     Int?

  @@index([rowRevisionId])
  @@map("collection_row_quotation_revisions")
}

// ─── Merchandising Plan ───────────────────────────────────────────────────────

/// Merchandising plan workflow status: DRAFT (editable) | CONFIRMED (locked for changes).
enum MerchandisingPlanStatus {
  DRAFT
  CONFIRMED
}

/// Gender target for a merchandising plan row: MAN | WOMAN | UNISEX | KID.
enum MerchandisingGender {
  MAN
  WOMAN
  UNISEX
  KID
}

/// Product lifecycle type: NEW_LINE (new category), NEW_STYLE (new design), NEW_COLOR (color extension), CARRY_OVER (rerun from prior season).
enum MerchandisingLifeType {
  NEW_LINE
  NEW_STYLE
  NEW_COLOR
  CARRY_OVER
}

/// Launch type for a row: SAMPLED (physical sample requested), OPEN_TO_BUY (available without sample).
enum MerchandisingLaunchType {
  SAMPLED
  OPEN_TO_BUY
}

/// Bill-of-materials section in a specsheet: UPPER | LINING | ACCESSORIES | SOLE | OTHER.
enum SpecsheetComponentSection {
  UPPER
  LINING
  ACCESSORIES
  SOLE
  OTHER
}

/// Merchandising plan for a brand+season pair. Unique per pair. Container for all SKU-level rows.
model MerchandisingPlan {
  id        String                  @id @default(uuid())
  /// FK to Brand. Restrict delete.
  brandId   String
  /// FK to Season. Restrict delete.
  seasonId  String
  /// Workflow status: DRAFT (editable) → CONFIRMED (locked).
  status    MerchandisingPlanStatus @default(DRAFT)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  /// The brand this plan belongs to.
  brand  Brand                  @relation(fields: [brandId], references: [id], onDelete: Restrict)
  /// The season this plan belongs to.
  season Season                 @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  /// SKU-level rows belonging to this plan.
  rows   MerchandisingPlanRow[]

  @@unique([brandId, seasonId])
  @@index([brandId, seasonId])
  @@map("merchandising_plans")
}

/// Single SKU row in a merchandising plan at colour granularity. One row = one article+colour combination.
model MerchandisingPlanRow {
  id     String @id @default(uuid())
  /// FK to MerchandisingPlan. Cascade delete.
  planId String
  /// Display order within the plan.
  order  Int    @default(0)

  articleCode         String
  styleDescription    String
  styleCode           String?
  colorCode           String
  colorDescription    String
  /// Gender target: MAN | WOMAN | UNISEX | KID.
  gender              MerchandisingGender
  productCategory     String
  lineCode            String?
  /// Lifecycle type: NEW_LINE | NEW_STYLE | NEW_COLOR | CARRY_OVER.
  lifeType            MerchandisingLifeType?
  /// Season code from which this style is carried over (if lifeType=CARRY_OVER).
  carryoverFromSeason String?

  /// Launch type: SAMPLED | OPEN_TO_BUY.
  launchType         MerchandisingLaunchType?
  smsPairsOrder      Int?
  targetPairs        Int?
  cancellationStatus String?
  designer           String?

  /// FK to PricingParameterSet (optional). SetNull if deleted.
  pricingParameterSetId String?

  targetFobPrice  Decimal? @db.Decimal(10, 4)
  firstOfferPrice Decimal? @db.Decimal(10, 4)
  finalOfferPrice Decimal? @db.Decimal(10, 4)
  retailTargetIt  Decimal? @db.Decimal(10, 4)
  wholesaleIt     Decimal? @db.Decimal(10, 4)
  retailTargetEu  Decimal? @db.Decimal(10, 4)
  wholesaleEu     Decimal? @db.Decimal(10, 4)

  pricingNotes String?
  generalNotes String?

  /// FK to User responsible for this row. SetNull if user is deleted.
  assignedUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The merchandising plan this row belongs to.
  plan                MerchandisingPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  /// Bill-of-materials specsheet linked to this row (1:1 optional).
  specsheet           MerchandisingSpecsheet?
  /// User assigned to work on this row.
  assignedUser        User?                   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  /// Pricing parameter set used for cost calculations on this row.
  pricingParameterSet PricingParameterSet?    @relation(fields: [pricingParameterSetId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([assignedUserId])
  @@index([pricingParameterSetId])
  @@map("merchandising_plan_rows")
}

/// Simplified bill-of-materials (specsheet) linked 1:1 to a merchandising plan row. Contains components and images.
model MerchandisingSpecsheet {
  id    String @id @default(uuid())
  /// FK to MerchandisingPlanRow. 1:1 — unique constraint enforced. Cascade delete.
  rowId String @unique

  madeIn       String?
  supplierName String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The plan row this specsheet belongs to.
  row        MerchandisingPlanRow     @relation(fields: [rowId], references: [id], onDelete: Cascade)
  /// BOM component lines (upper, lining, sole, etc.).
  components MerchandisingComponent[]
  /// Product images for this specsheet.
  images     MerchandisingImage[]

  @@map("merchandising_specsheets")
}

/// Single BOM component line within a specsheet (e.g. upper leather, sole rubber).
model MerchandisingComponent {
  id          String                    @id @default(uuid())
  /// FK to MerchandisingSpecsheet. Cascade delete.
  specsheetId String
  /// Display order within section.
  order       Int                       @default(0)
  /// BOM section: UPPER | LINING | ACCESSORIES | SOLE | OTHER.
  section     SpecsheetComponentSection

  partNumber   String?
  component    String
  material     String?
  color        String?
  pantoneNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The specsheet this component belongs to.
  specsheet MerchandisingSpecsheet @relation(fields: [specsheetId], references: [id], onDelete: Cascade)

  @@index([specsheetId, section, order])
  @@map("merchandising_components")
}

/// Image in a specsheet gallery. Stored in the storage layer; key references the bucket path.
model MerchandisingImage {
  id          String  @id @default(uuid())
  /// FK to MerchandisingSpecsheet. Cascade delete.
  specsheetId String
  /// Storage key for the image file. Null until the upload is confirmed.
  key         String?
  /// True if this is the primary display image for the specsheet.
  isDefault   Boolean @default(false)
  /// Display order within the gallery.
  order       Int     @default(0)
  caption     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The specsheet this image belongs to.
  specsheet MerchandisingSpecsheet @relation(fields: [specsheetId], references: [id], onDelete: Cascade)

  @@index([specsheetId, order])
  @@map("merchandising_images")
}

// ─── Portafoglio Analytics Sync ───────────────────────────────────────────────
//
// Repliche analytics delle tabelle NAV usate dalla query portafoglio ordini.
// Prefisso nav_pf_ (portafoglio) per distinguerle dalle nav_* entity-dual.
// Aggiornate dal sync service (background ogni 5 min + trigger manuale).
// NO soft-delete, NO entità locale: sono repliche pure in sola lettura dall'app.

/// Sync state tracker per NAV portafoglio table. navRowversion = CONVERT(BIGINT, MAX(timestamp)) from last SQL Server sync. 0 for full-refresh tables.
model NavPfSyncState {
  /// Table name used as PK (e.g. "nav_pf_sales_header").
  tableName      String    @id
  /// Last NAV rowversion processed. 0 for full-refresh tables (date_prenotazione, ddt_picking).
  lastRowversion BigInt    @default(0)
  lastSyncedAt   DateTime?
  /// Number of rows present after the last sync.
  rowCount       Int       @default(0)
  /// Duration of the last sync in milliseconds.
  lastDurationMs Int?

  @@map("nav_pf_sync_state")
}

