// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  admin
  editor
  viewer
}

enum Provider {
  LOCAL
  LDAP
  OIDC
}

enum TokenType {
  RESET
  VERIFY
}

// Models
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  username          String    @unique
  firstName         String    @default("")
  lastName          String    @default("")
  role              Role
  isActive          Boolean   @default(true)
  pendingApproval   Boolean   @default(false)
  locale            String    @default("it-IT")
  timezone          String    @default("Europe/Rome")
  tokenVersion      Int       @default(0)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  loginCount        Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  identities Identity[]
  auditLogs  AuditLog[]
  tokens     UserToken[]
  sectionAccess UserSectionAccess[]
  brandAccess UserBrandAccess[]
  seasonAccess UserSeasonAccess[]
  assignedMerchandisingRows MerchandisingPlanRow[]
  dashboardConfig DashboardConfig?
  dashboardTasks  DashboardTask[]

  @@map("users")
}

model Identity {
  id         String   @id @default(uuid())
  userId     String
  provider   Provider
  providerId String
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  localCredential LocalCredential?

  @@unique([provider, providerId])
  @@map("identities")
}

model LocalCredential {
  id           String   @id @default(uuid())
  identityId   String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@map("local_credentials")
}

model AppConfig {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  isEncrypted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("app_configs")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  // Sostituisce userId (più chiaro)
  action     String   // SCREAMING_SNAKE_CASE (es. USER_CREATE)
  targetType String   // Tipo risorsa (User, Config, Auth)
  targetId   String?  // ID risorsa target (opzionale)
  result     String   // SUCCESS o FAILURE (esplicito)
  metadata   Json?    // Dati redatti
  traceId    String?
  ip         String?  // Rinomina da ipAddress per brevità
  createdAt  DateTime @default(now()) // Rinomina da timestamp
  
  // Relations
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model UserToken {
  id         String    @id @default(uuid())
  userId     String
  type       TokenType
  tokenHash  String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, tokenHash])
  @@index([userId, type])
  @@map("user_tokens")
}

model FileObject {
  id             String    @id @default(uuid())
  bucket         String
  key            String
  originalName   String
  size           Int
  contentType    String
  checksumSha256 String
  createdBy      String
  cleanupStatus  String    @default("PENDING")  // PENDING | SUCCESS | FAILED
  cleanupAttempts Int      @default(0)
  lastCleanupAt  DateTime?
  confirmedAt    DateTime?                       // null = pending confirmation; set on entity link
  createdAt      DateTime  @default(now())

  @@unique([bucket, key])
  @@index([bucket, key])
  @@index([createdAt])
  @@index([createdBy])
  @@index([cleanupStatus])
  @@index([confirmedAt])
  @@map("file_objects")
}

model UserSectionAccess {
  id        String   @id @default(uuid())
  userId    String
  section   String   // 'settings' | 'maintenance'
  enabled   Boolean  // true=allow, false=deny
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, section])
  @@index([userId, section])
  @@map("user_section_access")
}

model Brand {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  logoKey     String?
  navBrandId  String?   @unique
  navBrand    NavBrand? @relation(fields: [navBrandId], references: [navCode], onDelete: SetNull)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  pricingParameterSets PricingParameterSet[]
  collectionLayouts    CollectionLayout[]
  merchandisingPlans   MerchandisingPlan[]
  userBrandAccess      UserBrandAccess[]
  userSeasonAccess     UserSeasonAccess[]

  @@index([name])
  @@index([isActive, name])
  @@map("brands")
}

model Season {
  id          String     @id @default(uuid())
  code        String     @unique
  year        Int?
  name        String
  navSeasonId String?    @unique
  navSeason   NavSeason? @relation(fields: [navSeasonId], references: [navCode], onDelete: SetNull)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  pricingParameterSets PricingParameterSet[]
  collectionLayouts    CollectionLayout[]
  merchandisingPlans   MerchandisingPlan[]
  userSeasonAccess     UserSeasonAccess[]

  @@map("seasons")
}

/**
 * Whitelist brand per utente.
 * Se NON esistono righe per un utente → accesso a tutti i brand (default).
 * Se esistono righe → accesso solo ai brand elencati.
 */
model UserBrandAccess {
  id      String @id @default(uuid())
  userId  String
  brandId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@index([userId])
  @@map("user_brand_access")
}

/**
 * Whitelist stagioni per utente+brand.
 * Se NON esistono righe per (userId, brandId) → accesso a tutte le stagioni di quel brand.
 * Se esistono righe → accesso solo alle stagioni elencate.
 */
model UserSeasonAccess {
  id       String @id @default(uuid())
  userId   String
  brandId  String
  seasonId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId, seasonId])
  @@index([userId, brandId])
  @@map("user_season_access")
}

model DashboardConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgets   Json
  updatedAt DateTime @updatedAt

  @@map("dashboard_configs")
}

model DashboardTask {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@map("dashboard_tasks")
}

/**
 * Preferenze utente consolidate in un singolo Json
 * Struttura: { lastBrandId?, lastSeasonId?, menuStates? }
 */
model UserPreference {
  userId    String   @id
  data      Json?    @default("{}")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("user_preferences")
}


/**
 * Set di parametri di pricing per brand+season
 * Ogni brand+season può avere più varianti (es. Pelle, Non Pelle, Tunisia)
 * I parametri guidano la calcolatrice di costi e prezzi
 */
model PricingParameterSet {
  id                     String   @id @default(uuid())
  brandId                String
  seasonId               String
  name                   String   // es. "Pelle", "Non Pelle", "Tunisia"
  countryCode            String   // es. "CN", "IT", "TR" — ISO 3166-1 alpha-2
  purchaseCurrency       String   @default("USD")
  sellingCurrency        String   @default("EUR")
  qualityControlPercent  Float
  transportInsuranceCost Float
  duty                   Float
  exchangeRate           Float
  italyAccessoryCosts    Float
  tools                  Float
  retailMultiplier       Float
  optimalMargin          Float
  isDefault              Boolean  @default(false)
  orderIndex             Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  brand  Brand  @relation(fields: [brandId], references: [id], onDelete: Restrict)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  quotations            CollectionRowQuotation[]
  merchandisingPlanRows MerchandisingPlanRow[]
  enabledForVendors     Vendor[]                 @relation("VendorEnabledParameterSets")

  @@unique([brandId, seasonId, name])
  @@index([brandId, seasonId])
  @@map("pricing_parameter_sets")
}

/**
 * Collection Layout — unico per brand+stagione
 * Rappresenta l'elenco delle linee che compongono una collezione stagionale
 */
model CollectionLayout {
  id               String   @id @default(uuid())
  brandId          String
  seasonId         String
  skuBudget        Int?
  hiddenColumns    Json?    // String[] — colonne nascoste, null = tutte visibili
  availableGenders String[] @default(["MAN","WOMAN"])
  brand            Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  season           Season   @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  groups           CollectionGroup[]
  rows             CollectionLayoutRow[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([brandId, seasonId])
  @@index([brandId, seasonId])
  @@map("collection_layouts")
}

/**
 * Gruppo di righe all'interno di un Collection Layout
 * Es. "Collezione Uomo", "Collezione Donna", "Special Edition"
 */
model CollectionGroup {
  id                 String           @id @default(uuid())
  collectionLayoutId String
  collectionLayout   CollectionLayout @relation(fields: [collectionLayoutId], references: [id], onDelete: Cascade)
  name               String
  order              Int              @default(0)
  skuBudget          Int?
  rows               CollectionLayoutRow[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([collectionLayoutId])
  @@map("collection_groups")
}

/**
 * Filtro di sincronizzazione per entità NAV.
 * Un record per entità (vendor, customer, item, …).
 * Controlla se il sync è attivo e quali No_ includere/escludere.
 */
model NavSyncFilter {
  id              String   @id @default(cuid())
  entity          String   // "vendor" | "brand" | "season"
  mode            String   // "all" | "whitelist" | "exclude"
  navNos          String[] // rilevante solo per whitelist/exclude
  active          Boolean  @default(true)
  note            String?
  /// Se true, lo scheduler sincronizza automaticamente questa entità
  autoSyncEnabled Boolean  @default(false)
  /// Frequenza di sync automatico in minuti (usata solo se autoSyncEnabled=true)
  intervalMinutes Int      @default(30)
  updatedAt       DateTime @updatedAt

  @@unique([entity])
  @@index([entity, active])
  @@map("nav_sync_filters")
}

/**
 * Replica della tabella [COMPANY$Vendor] di Microsoft NAV
 * Il campo timestamp NAV è usato solo nelle query di sync differenziale
 * (WHERE timestamp > @lastTimestamp) — non è mappato nel modello.
 */
model NavVendor {
  navNo           String    @id              // No_
  name            String                     // Name
  name2           String?                    // Name 2
  searchName      String?                    // Search Name
  firstName       String?                    // First Name
  lastName        String?                    // Last Name

  address         String?                    // Address
  address2        String?                    // Address 2
  postCode        String?                    // Post Code
  city            String?                    // City
  county          String?                    // County
  countryCode     String?                    // Country_Region Code

  phoneNo         String?                    // Phone No_
  faxNo           String?                    // Fax No_
  email           String?                    // E-Mail
  homePage        String?                    // Home Page
  contact         String?                    // Contact

  vendorType      String?                    // Vendor Type

  navLastModified DateTime?                  // Last Date Modified
  syncedAt        DateTime                   // timestamp ultimo sync

  vendor          Vendor?                    // collegamento all'anagrafica interna

  @@index([name])
  @@index([syncedAt])
  @@index([navLastModified])
  @@map("nav_vendors")
}

/**
 * Replica della tabella [COMPANY$Brand] di Microsoft NAV
 */
model NavBrand {
  navCode     String   @id              // Code (PK)
  description String   @default("")     // Description
  syncedAt    DateTime                  // timestamp ultimo sync

  brand       Brand?                    // collegamento all'anagrafica interna

  @@index([description])
  @@map("nav_brands")
}

/**
 * Replica della tabella [COMPANY$Season] di Microsoft NAV
 */
model NavSeason {
  navCode      String    @id            // Code (PK)
  description  String    @default("")   // Description
  startingDate DateTime?                // Starting Date
  endingDate   DateTime?                // Ending Date
  syncedAt     DateTime                 // timestamp ultimo sync

  season       Season?                  // collegamento all'anagrafica interna

  @@index([description])
  @@map("nav_seasons")
}

/**
 * Anagrafica interna fornitori
 * Entità standalone — può esistere indipendentemente da NAV.
 * Il campo navVendorId è opzionale: se valorizzato collega il fornitore
 * alla corrispondente voce su Microsoft NAV.
 */
model Vendor {
  id          String    @id @default(uuid())
  name        String
  countryCode String?
  nickname    String?
  referente   String?
  email       String?
  phone       String?
  chat        String?
  notes       String?
  navVendorId String?   @unique
  navVendor   NavVendor? @relation(fields: [navVendorId], references: [navNo], onDelete: SetNull)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  collectionRows       CollectionLayoutRow[]
  enabledParameterSets PricingParameterSet[] @relation("VendorEnabledParameterSets")

  @@index([name])
  @@index([isActive])
  @@map("vendors")
}

/**
 * Singola riga del Collection Layout
 * Rappresenta una linea/stile all'interno di una collezione
 */
model CollectionLayoutRow {
  id                     String                @id @default(uuid())
  collectionLayoutId     String
  collectionLayout       CollectionLayout      @relation(fields: [collectionLayoutId], references: [id], onDelete: Cascade)
  groupId                String
  group                  CollectionGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  order                  Int                   @default(0)

  // Required fields
  gender                 String                // validated against layout.availableGenders
  vendorId               String?
  vendor                 Vendor?               @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  line                   String
  article                String?               // testo libero corto, dopo line
  status                 String                // catalog-managed (lineStatus)
  skuForecast            Int
  qtyForecast            Int
  productCategory        String

  // Optional — identification/progress
  strategy               String?               // catalog-managed
  styleStatus            String?               // catalog-managed
  progress               String?               // catalog-managed
  designer               String?
  pictureKey             String?

  // Optional — notes
  styleNotes             String?
  materialNotes          String?
  colorNotes             String?
  toolingNotes           String?

  // Optional — pricing
  toolingQuotation       Float?
  quotations             CollectionRowQuotation[]

  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([collectionLayoutId])
  @@index([groupId])
  @@index([vendorId])
  @@map("collection_layout_rows")
}

/**
 * Quotazione di pricing per una riga collection
 * Una riga può avere N quotazioni con parametri diversi (es. CN/USD vs IT/EUR)
 */
model CollectionRowQuotation {
  id                    String               @id @default(uuid())
  rowId                 String
  row                   CollectionLayoutRow  @relation(fields: [rowId], references: [id], onDelete: Cascade)
  order                 Int                  @default(0)
  pricingParameterSetId String?
  pricingParameterSet   PricingParameterSet? @relation(fields: [pricingParameterSetId], references: [id], onDelete: SetNull)
  retailPrice           Float?
  supplierQuotation     Float?               // FOB in purchaseCurrency del param set
  notes                 String?
  sku                   Int?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([rowId])
  @@index([pricingParameterSetId])
  @@map("collection_row_quotations")
}

/**
 * Catalog items configurabili per collection layout
 * Tipi: strategy, lineStatus, styleStatus, progress
 */
model CollectionCatalogItem {
  id        String   @id @default(uuid())
  type      String   // "strategy" | "lineStatus" | "styleStatus" | "progress"
  value     String
  label     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, value])
  @@index([type, isActive])
  @@map("collection_catalog_items")
}

// ─── Merchandising Plan ───────────────────────────────────────────────────────

enum MerchandisingPlanStatus {
  DRAFT
  CONFIRMED
}

enum MerchandisingGender {
  MAN
  WOMAN
  UNISEX
  KID
}

enum MerchandisingLifeType {
  NEW_LINE
  NEW_STYLE
  NEW_COLOR
  CARRY_OVER
}

enum MerchandisingLaunchType {
  SAMPLED
  OPEN_TO_BUY
}

enum SpecsheetComponentSection {
  UPPER
  LINING
  ACCESSORIES
  SOLE
  OTHER
}

/**
 * Piano merchandising per brand+stagione — unico per coppia
 */
model MerchandisingPlan {
  id        String                  @id @default(uuid())
  brandId   String
  seasonId  String
  status    MerchandisingPlanStatus @default(DRAFT)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  brand   Brand                 @relation(fields: [brandId], references: [id], onDelete: Restrict)
  season  Season                @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  rows    MerchandisingPlanRow[]

  @@unique([brandId, seasonId])
  @@index([brandId, seasonId])
  @@map("merchandising_plans")
}

/**
 * Riga SKU del piano merchandising (granularità colore)
 */
model MerchandisingPlanRow {
  id     String @id @default(uuid())
  planId String
  order  Int    @default(0)

  articleCode         String
  styleDescription    String
  styleCode           String?
  colorCode           String
  colorDescription    String
  gender              MerchandisingGender
  productCategory     String
  lineCode            String?
  lifeType            MerchandisingLifeType?
  carryoverFromSeason String?

  launchType         MerchandisingLaunchType?
  smsPairsOrder      Int?
  targetPairs        Int?
  cancellationStatus String?
  designer           String?

  pricingParameterSetId String?

  targetFobPrice   Decimal? @db.Decimal(10, 4)
  firstOfferPrice  Decimal? @db.Decimal(10, 4)
  finalOfferPrice  Decimal? @db.Decimal(10, 4)
  retailTargetIt   Decimal? @db.Decimal(10, 4)
  wholesaleIt      Decimal? @db.Decimal(10, 4)
  retailTargetEu   Decimal? @db.Decimal(10, 4)
  wholesaleEu      Decimal? @db.Decimal(10, 4)

  pricingNotes String?
  generalNotes String?

  assignedUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan                MerchandisingPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  specsheet           MerchandisingSpecsheet?
  assignedUser        User?                   @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  pricingParameterSet PricingParameterSet?    @relation(fields: [pricingParameterSetId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@index([assignedUserId])
  @@index([pricingParameterSetId])
  @@map("merchandising_plan_rows")
}

/**
 * Specsheet (BOM semplificata) collegata 1:1 a una riga piano
 */
model MerchandisingSpecsheet {
  id    String @id @default(uuid())
  rowId String @unique

  madeIn       String?
  supplierName String?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  row        MerchandisingPlanRow     @relation(fields: [rowId], references: [id], onDelete: Cascade)
  components MerchandisingComponent[]
  images     MerchandisingImage[]

  @@map("merchandising_specsheets")
}

/**
 * Componente BOM di una specsheet
 */
model MerchandisingComponent {
  id          String                    @id @default(uuid())
  specsheetId String
  order       Int                       @default(0)
  section     SpecsheetComponentSection

  partNumber   String?
  component    String
  material     String?
  color        String?
  pantoneNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specsheet MerchandisingSpecsheet @relation(fields: [specsheetId], references: [id], onDelete: Cascade)

  @@index([specsheetId, section, order])
  @@map("merchandising_components")
}

/**
 * Immagini di una specsheet (galleria)
 */
model MerchandisingImage {
  id          String  @id @default(uuid())
  specsheetId String
  key         String?
  isDefault   Boolean @default(false)
  order       Int     @default(0)
  caption     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  specsheet MerchandisingSpecsheet @relation(fields: [specsheetId], references: [id], onDelete: Cascade)

  @@index([specsheetId, order])
  @@map("merchandising_images")
}

// ─── Portafoglio Analytics Sync ───────────────────────────────────────────────
//
// Repliche analytics delle tabelle NAV usate dalla query portafoglio ordini.
// Prefisso nav_pf_ (portafoglio) per distinguerle dalle nav_* entity-dual.
// Aggiornate dal sync service (background ogni 5 min + trigger manuale).
// NO soft-delete, NO entità locale: sono repliche pure in sola lettura dall'app.

/**
 * Stato di sincronizzazione per tabella.
 * navRowversion = CONVERT(BIGINT, MAX(timestamp)) dell'ultimo sync su SQL Server.
 * Per le tabelle full-refresh (date_prenotazione, ddt_picking): rowversion = 0.
 */
model NavPfSyncState {
  tableName       String    @id
  lastRowversion  BigInt    @default(0)
  lastSyncedAt    DateTime?
  rowCount        Int       @default(0)
  lastDurationMs  Int?

  @@map("nav_pf_sync_state")
}

/** Replica di [Company$Sales Header] */
model NavPfSalesHeader {
  no_                       String    @id
  documentType              Int
  orderDate                 DateTime?
  sellToCustomerNo          String?
  billToCustomerNo          String?
  billToName                String?
  salespersonCode           String?
  areaManagerCode           String?
  subject1                  String?
  subject2                  String?
  currencyCode              String?
  shipToCode                String?
  shipToName                String?
  shipToName2               String?
  shipToAddress             String?
  shipToAddress2            String?
  shipToCity                String?
  shipToPostCode            String?
  shipToCounty              String?
  shipmentMethodCode        String?
  transportReasonCode       String?
  shippingAgentCode         String?
  shippingAgentServiceCode  String?
  paymentTermsCode          String?
  paymentMethodCode         String?
  invoiceDiscountCalculation String?
  invoiceDiscountValue      Float?
  consignment               Int?
  rightOnReturnPct          Float?
  note                      String?
  campaignNo                String?
  securitiesReceived        String?
  anomalous                 Int?
  notAnomalous              Int?
  anomalousDate             DateTime?
  checked                   Int?
  checkedDate               DateTime?
  budgetNo                  String?
  courseDate                DateTime?
  kimoFashionSoNo           String?
  orderType                 Int?
  fastShipping              Int?
  commissionGroupCode       String?
  geographicalZone          String?
  sellingSeasonCode         String?
  shortcutDimension2Code    String?
  customerPostingGroup      String?
  navRowversion             BigInt    @default(0)

  @@index([sellingSeasonCode])
  @@index([shortcutDimension2Code])
  @@index([sellingSeasonCode, shortcutDimension2Code])
  @@index([salespersonCode])
  @@index([sellToCustomerNo])
  @@map("nav_pf_sales_header")
}

/** Replica di [Company$Sales Line] */
model NavPfSalesLine {
  documentType              Int
  documentNo                String
  lineNo                    Int
  type                      Int?
  no_                       String?
  customerOrderRef          String?
  reference                 String?
  genBusPostingGroup        String?
  vatBusPostingGroup        String?
  unitOfMeasure             String?
  constantVariableCode      String?
  assortmentCode            String?
  deleteReason              String?
  salesPurchaseStatusCode   String?
  salesPurchaseStatusItem   String?
  deleteDate                DateTime?
  customerPriceGroup        String?
  averageUnitPrice          Float?
  noOfPairs                 Float?
  quantity                  Float?
  lineAmount                Float?
