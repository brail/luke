/// Pre-aggregation of [Company$Reserv__Assign_ Link] (type 1). Stores MAX(Date Reservation) per (Sales Document No_, Sales Line No_). Full-refresh each sync cycle, scoped to document nos in nav_pf_sales_header.
model NavPfDatePrenotazione {
  salesDocumentNo String
  salesLineNo     Int
  dateReservation DateTime?
  syncedAt        DateTime  @default(now())

  @@id([salesDocumentNo, salesLineNo])
  @@map("nav_pf_date_prenotazione")
}

/// Pre-aggregation of [Company$DDT_Picking Line] JOIN [Company$DDT_Picking Header]. Stores SUM per status per (Order No_, Order Line No_). Full-refresh each sync cycle, scoped to document nos in nav_pf_sales_header.
model NavPfDdtPicking {
  orderNo             String
  orderLineNo         Int
  pairsTotale         Float?
  qtyTotale           Float?
  pairsRilasciate     Float?
  qtyRilasciate       Float?
  pairsAperte         Float?
  qtyAperte           Float?
  pairsDaInviareWmsps Float?
  qtyDaInviareWmsps   Float?
  pairsInviatoWmsps   Float?
  qtyInviatoWmsps     Float?
  pairsEvasoWmsps     Float?
  qtyEvasoWmsps       Float?
  syncedAt            DateTime @default(now())

  @@id([orderNo, orderLineNo])
  @@index([orderNo])
  @@map("nav_pf_ddt_picking")
}

// ─── Repliche tabelle KIMO-FASHION ────────────────────────────────────────────
// Prefisso nav_kimo_ per distinguerle dalle nav_pf_* (portafoglio).
// Alimentate da nav-kimo-sync.ts (background scheduler separato).
// Sync state condiviso con nav_pf_sync_state (stesso schema, prefisso nav_kimo_).

/// Read-only replica of [Company$KIMO-FASHION Sales Order Hdr] from NAV. Incrementally synced via rowversion.
model NavKimoSalesHeader {
  entryNo                 BigInt    @id
  trademarkCode           String?
  sellingSeasonCode       String?
  salespersonCodeNav      String?
  assignedSalesDocumentNo String?
  sellToCustomerNo        String?
  createSoDateTime        DateTime?
  releaseSoDateTime       DateTime?
  kimoDocumentType        String?
  navRowversion           BigInt    @default(0)

  @@index([trademarkCode])
  @@index([sellingSeasonCode])
  @@index([trademarkCode, sellingSeasonCode])
  @@index([salespersonCodeNav])
  @@index([assignedSalesDocumentNo])
  @@index([sellToCustomerNo])
  @@map("nav_kimo_sales_header")
}

/// Read-only replica of [Company$KIMO-FASHION Sales Order Line] from NAV. PK = Entry No_ (BigInt unique per row). Line No_ does not exist in this NAV table.
model NavKimoSalesLine {
  entryNo                BigInt  @id
  headerEntryNo          BigInt
  no_                    String?
  modelItemNo            String?
  colorCode              String?
  sizeCode               String?
  quantity               Float?
  lineAmount             Float?
  kimoFashionSoReference String?
  type                   Int?
  navRowversion          BigInt  @default(0)

  @@index([headerEntryNo])
  @@index([modelItemNo])
  @@map("nav_kimo_sales_line")
}

// ─── Company Structure ────────────────────────────────────────────────────────

/// Singleton company profile record. Always queried by id="singleton". Holds legal, contact and export settings.
model CompanyProfile {
  /// Fixed PK "singleton" — only one record allowed per deployment.
  id             String   @id @default("singleton")
  legalName      String
  displayName    String
  countryCode    String?
  vatNumber      String?
  taxCode        String?
  phone          String?
  email          String?
  website        String?
  /// Structured postal address as JSON blob.
  address        Json?
  /// Export configuration settings as JSON blob.
  exportSettings Json?
  /// Storage key for the company logo in the "assets" bucket.
  logoKey        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("company_profile")
}

/// Organisational function (department/team unit) within the company. Used to scope calendar event visibility and team structure.
model CompanyFunction {
  id          String   @id @default(uuid())
  /// URL-safe slug used as stable identifier in configs and routes.
  slug        String
  name        String
  description String?
  /// Display order in function listings.
  order       Int      @default(0)
  /// Soft-delete flag.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Teams belonging to this function.
  teams                     CompanyTeam[]
  /// Calendar events owned by this function.
  ownedCalendarEvents       CalendarEvent[]                   @relation("CalendarEventOwnerFunction")
  /// Calendar event visibility grants for this function.
  calendarEventVisibilities CalendarEventVisibility[]
  /// Milestone template items owned by this function.
  ownedTemplateItems        MilestoneTemplateItem[]           @relation("TemplateItemOwnerFunction")
  /// Milestone template item visibility grants for this function.
  templateItemVisibilities  MilestoneTemplateItemVisibility[]
  /// Google Calendar bindings for this function.
  googleCalendarBindings    GoogleCalendarBinding[]
  /// Google event mappings for calendar events visible to this function.
  googleEventMappings       GoogleEventMapping[]

  @@index([slug])
  @@index([isActive, order])
  @@map("company_functions")
}

/// Role a user holds within a company team: LEADER (can manage team) or MEMBER (standard member).
enum CompanyTeamMemberRole {
  LEADER
  MEMBER
}

/// Team within a company function. A function can have multiple teams; team names are unique within a function.
model CompanyTeam {
  id          String   @id @default(uuid())
  /// FK to CompanyFunction. Restrict delete.
  functionId  String
  name        String
  description String?
  /// Soft-delete flag.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// The function this team belongs to.
  function    CompanyFunction         @relation(fields: [functionId], references: [id], onDelete: Restrict)
  /// User memberships in this team.
  memberships CompanyTeamMembership[]
  /// Brand scopes this team has access to.
  brandScopes CompanyTeamBrandScope[]

  @@unique([functionId, name])
  @@index([functionId])
  @@map("company_teams")
}

/// M2M join table between CompanyTeam and User. Tracks role within the team.
model CompanyTeamMembership {
  /// FK to CompanyTeam. Cascade delete.
  teamId    String
  /// FK to User. Cascade delete.
  userId    String
  /// Role in this team: LEADER or MEMBER.
  role      CompanyTeamMemberRole @default(MEMBER)
  createdAt DateTime              @default(now())

  /// The team this membership belongs to.
  team CompanyTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  /// The user who is a member.
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
  @@map("company_team_memberships")
}

/// M2M join table granting a CompanyTeam access to a specific Brand.
model CompanyTeamBrandScope {
  /// FK to CompanyTeam. Cascade delete.
  teamId  String
  /// FK to Brand. Cascade delete.
  brandId String

  /// The team being granted access.
  team  CompanyTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  /// The brand the team has access to.
  brand Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([teamId, brandId])
  @@index([brandId])
  @@map("company_team_brand_scopes")
}

/// Per-user visibility grant for a calendar event. Allows sharing individual events with specific users outside the normal function-based visibility.
model CalendarEventUserVisibility {
  /// FK to CalendarEvent. Cascade delete.
  eventId   String
  /// FK to User (recipient). Cascade delete.
  userId    String
  grantedAt DateTime @default(now())
  /// FK to User (grantor). SetNull if the grantor is deleted.
  grantedBy String?

  /// The calendar event being shared.
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// The user receiving visibility.
  user    User          @relation("CalendarEventUserVisibilityRecipient", fields: [userId], references: [id], onDelete: Cascade)
  /// The user who granted visibility, if any.
  grantor User?         @relation("CalendarEventUserVisibilityGrantor", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@id([eventId, userId])
  @@index([userId])
  @@map("calendar_event_user_visibilities")
}

/// M2M join table granting a CompanyFunction visibility of a MilestoneTemplateItem.
model MilestoneTemplateItemVisibility {
  /// FK to MilestoneTemplateItem. Cascade delete.
  templateItemId String
  /// FK to CompanyFunction. Restrict delete.
  functionId     String

  /// The template item being shared.
  templateItem MilestoneTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)
  /// The function receiving visibility.
  function     CompanyFunction       @relation(fields: [functionId], references: [id], onDelete: Restrict)

  @@id([templateItemId, functionId])
  @@index([functionId])
  @@map("milestone_template_item_visibilities")
}

// ─── Season Calendar ──────────────────────────────────────────────────────────

/// Season calendar lifecycle status: DRAFT (setup in progress) | ACTIVE (live, visible to all) | ARCHIVED (read-only).
enum SeasonCalendarStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/// Which holiday calendar(s) count toward an event's working-days deadline countdown, if any.
/// Null (unset) means the deadline countdown stays in plain calendar days — this is opt-in per
/// event/template item, not a default behavior change. COMPANY resolves to `CompanyProfile.countryCode`;
/// VENDOR resolves per-row to `CollectionLayoutRow.vendor.countryCode`; BOTH excludes a day only if
/// it's a working day in both calendars. See docs/TASK_working_days_calendar_relevance.md.
enum CalendarDaysRelevance {
  COMPANY
  VENDOR
  BOTH
}

/// Calendar event workflow status: PLANNED → IN_PROGRESS → COMPLETED | CANCELLED.
enum CalendarEventStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// Type of state side-effect a calendar event can trigger on an entity: LOCK_COLLECTION_LAYOUT | UNLOCK_COLLECTION_LAYOUT.
enum StateEffectType {
  LOCK_COLLECTION_LAYOUT
  UNLOCK_COLLECTION_LAYOUT
}

/// Vendor period type: CLOSURE (vendor unavailable) | OPEN (override — vendor is open despite a holiday).
enum VendorOverrideType {
  CLOSURE
  OPEN
}

/// Season calendar for a brand+season pair. Unique per pair. Owns N PlanningGroups (always at least
/// one default) which carry the per-group anchorDate/frozenAt.
model SeasonCalendar {
  id         String               @id @default(uuid())
  /// FK to Brand. Restrict delete.
  brandId    String
  /// FK to Season. Restrict delete.
  seasonId   String
  /// Lifecycle status: DRAFT → ACTIVE → ARCHIVED.
  status     SeasonCalendarStatus @default(DRAFT)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  /// The brand this calendar belongs to.
  brand          Brand                   @relation(fields: [brandId], references: [id], onDelete: Restrict)
  /// The season this calendar belongs to.
  season         Season                  @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  /// Events scheduled in this calendar.
  events         CalendarEvent[]
  /// Google Calendar bindings per company function.
  bindings       GoogleCalendarBinding[]
  /// Planning groups scoping this calendar's events and the collection layout's rows.
  planningGroups PlanningGroup[]

  @@unique([brandId, seasonId])
  @@index([seasonId])
  @@map("season_calendars")
}

/// A named scope within a SeasonCalendar decoupling calendar events from collection layout rows: an
/// event applies to exactly the rows sharing its planningGroupId. Every SeasonCalendar gets exactly
/// one auto-created default group (isDefault=true, never renamed/deleted); additional groups support
/// parallel plans. Owns anchorDate/frozenAt — template application and freeze are per-group.
model PlanningGroup {
  id         String    @id @default(uuid())
  /// FK to SeasonCalendar. Cascade delete — a calendar's groups are meaningless once it's gone.
  calendarId String
  name       String
  /// True only for the single auto-created group per calendar. Enforced by a partial unique index
  /// (see migration) plus an application-level check on creation — cannot be renamed or deleted.
  isDefault  Boolean   @default(false)
  /// Reference date for milestone template offset calculations, scoped to this group. Date only.
  anchorDate DateTime? @db.Date
  /// Timestamp when this group's baseline was frozen. One-shot — never re-frozen without admin unfreeze.
  frozenAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  /// The season calendar this group belongs to.
  calendar SeasonCalendar        @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  /// Calendar events scoped to this group.
  events   CalendarEvent[]
  /// Collection layout rows scoped to this group.
  rows     CollectionLayoutRow[]

  @@unique([calendarId, name])
  @@index([calendarId])
  @@map("planning_groups")
}

/// Single event in a season calendar. Section visibility managed via CalendarEventVisibility (M2M with CompanyFunction).
model CalendarEvent {
  id                String              @id @default(uuid())
  /// FK to SeasonCalendar. Cascade delete.
  calendarId        String
  /// FK to PlanningGroup. Restrict delete — a group can't be deleted while it still owns events.
  planningGroupId   String
  /// FK to CompanyFunction that owns this event. Restrict delete.
  ownerFunctionId   String
  /// Event type key from CalendarCatalogItem (type="eventType"). E.g. "KICKOFF", "SAMPLE_APPROVAL".
  type              String
  /// FK to Phase (optional, additive to type). Null for non-productive events (e.g. review meetings).
  phaseId           String?
  /// Which holiday calendar(s) count toward this event's working-days deadline, if any. Null =
  /// plain calendar days (default, unchanged behavior). Propagated from templateItem on generation.
  calendarDaysRelevance CalendarDaysRelevance?
  /// Workflow status: PLANNED → IN_PROGRESS → COMPLETED | CANCELLED.
  status            CalendarEventStatus @default(PLANNED)
  title             String
  description       String?
  startAt           DateTime
  endAt             DateTime?
  /// Snapshot of startAt at freeze time. Written once by freezeCalendar, never updated afterwards —
  /// the immutable "planned" baseline against which drift is measured. Null until the calendar is frozen.
  baselineStartAt   DateTime?
  /// Snapshot of endAt at freeze time. Same immutability contract as baselineStartAt.
  baselineEndAt     DateTime?
  /// True if the event spans the full day (time portion ignored).
  allDay            Boolean             @default(false)
  /// If true, the event is exported to Google Calendar for visible functions.
  publishExternally Boolean             @default(true)
  /// FK to MilestoneTemplateItem that generated this event (optional). SetNull if template item is deleted.
  templateItemId    String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  /// The season calendar this event belongs to.
  calendar         SeasonCalendar                 @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  /// The planning group this event applies to — determines which rows see it.
  planningGroup    PlanningGroup                  @relation(fields: [planningGroupId], references: [id], onDelete: Restrict)
  /// The company function that owns this event.
  ownerFunction    CompanyFunction                @relation("CalendarEventOwnerFunction", fields: [ownerFunctionId], references: [id], onDelete: Restrict)
  /// The milestone template item that generated this event, if any.
  templateItem     MilestoneTemplateItem?         @relation(fields: [templateItemId], references: [id], onDelete: SetNull)
  /// The phase this event represents, if any.
  phase            Phase?                         @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  /// Function-level visibility grants for this event.
  visibilities     CalendarEventVisibility[]
  /// Personal notes written by individual users on this event.
  notes            CalendarEventPersonalNote[]
  /// Google event mappings per function.
  eventMappings    GoogleEventMapping[]
  /// Per-user visibility grants for this event.
  userVisibilities CalendarEventUserVisibility[]
  /// State side-effects (e.g. lock/unlock collection layout) triggered by this event.
  stateEffects     CalendarEventStateEffect[]
  /// Execution records for state effects of this event.
  effectExecutions CalendarEventEffectExecution[]
  /// Collection layouts locked by this event.
  lockedLayouts    CollectionLayout[]

  @@index([calendarId, startAt])
  @@index([planningGroupId])
  @@index([ownerFunctionId])
  @@index([phaseId])
  @@map("calendar_events")
}

/// M2M visibility grant: which CompanyFunctions can see a CalendarEvent. The ownerFunction is always included with readOnly=false.
model CalendarEventVisibility {
  /// FK to CalendarEvent. Cascade delete.
  eventId    String
  /// FK to CompanyFunction. Restrict delete.
  functionId String
  /// If true, the function can see but not edit the event.
  readOnly   Boolean @default(true)

  /// The calendar event being shared.
  event    CalendarEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// The function receiving visibility.
  function CompanyFunction @relation(fields: [functionId], references: [id], onDelete: Restrict)

  @@id([eventId, functionId])
  @@index([functionId])
  @@map("calendar_event_visibilities")
}

/// Personal note written by a user on a specific calendar event. Not synced to Google Calendar. One note per user per event.
model CalendarEventPersonalNote {
  id        String   @id @default(uuid())
  /// FK to CalendarEvent. Cascade delete.
  eventId   String
  /// FK to User. Cascade delete.
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The calendar event this note is attached to.
  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// The user who wrote this note.
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("calendar_event_personal_notes")
}

/// Reusable milestone template (catalogue). Applied to a SeasonCalendar to generate CalendarEvents from offset-based items.
model MilestoneTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Template items (milestones) belonging to this template.
  items MilestoneTemplateItem[]

  @@map("milestone_templates")
}

/// Single milestone item within a template. Defines an event to be created at the target PlanningGroup's anchorDate + offsetDays.
model MilestoneTemplateItem {
  id                String   @id @default(uuid())
  /// FK to MilestoneTemplate. Cascade delete.
  templateId        String
  /// FK to CompanyFunction that will own the generated event. Restrict delete.
  ownerFunctionId   String
  /// Event type key from CalendarCatalogItem (type="eventType").
  type              String
  /// FK to Phase (optional, additive to type). Propagated to CalendarEvent.phaseId on generation.
  phaseId           String?
  /// Propagated to CalendarEvent.calendarDaysRelevance on generation. See CalendarEvent field doc.
  calendarDaysRelevance CalendarDaysRelevance?
  title             String
  description       String?
  /// Days offset from the target PlanningGroup's anchorDate to compute event startAt.
  offsetDays        Int
  /// Duration of the generated event in days. 0 = single-day event.
  durationDays      Int      @default(0)
  /// Propagated to CalendarEvent.allDay on generation.
  allDay            Boolean  @default(true)
  /// If true, the generated event is exported to Google Calendar.
  publishExternally Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  /// The template this item belongs to.
  template      MilestoneTemplate                 @relation(fields: [templateId], references: [id], onDelete: Cascade)
  /// The function that will own the generated event.
  ownerFunction CompanyFunction                   @relation("TemplateItemOwnerFunction", fields: [ownerFunctionId], references: [id], onDelete: Restrict)
  /// The phase this template item represents, if any.
  phase         Phase?                            @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  /// Calendar events generated from this template item.
  events        CalendarEvent[]
  /// Function visibility grants for this template item.
  visibilities  MilestoneTemplateItemVisibility[]
  /// State effects to apply when a generated event is completed.
  stateEffects  MilestoneTemplateStateEffect[]

  @@index([templateId])
  @@index([ownerFunctionId])
  @@index([phaseId])
  @@map("milestone_template_items")
}

/// Binding between a SeasonCalendar+CompanyFunction pair and the corresponding Google Calendar ID. Created lazily on first sync.
model GoogleCalendarBinding {
  id                String   @id @default(uuid())
  /// FK to SeasonCalendar. Cascade delete.
  seasonCalendarId  String
  /// FK to CompanyFunction. Restrict delete.
  companyFunctionId String
  /// Google Calendar ID (e.g. "abc123@group.calendar.google.com").
  googleCalendarId  String
  /// True once the Google Calendar has been created and ACLs set up.
  isProvisioned     Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  /// The season calendar this binding belongs to.
  seasonCalendar  SeasonCalendar  @relation(fields: [seasonCalendarId], references: [id], onDelete: Cascade)
  /// The company function this binding applies to.
  companyFunction CompanyFunction @relation(fields: [companyFunctionId], references: [id], onDelete: Restrict)

  @@unique([seasonCalendarId, companyFunctionId])
  @@index([googleCalendarId])
  @@index([companyFunctionId])
  @@map("google_calendar_bindings")
}

/// Maps a CalendarEvent to a Google Calendar event per visible CompanyFunction. contentHash is deterministic — a change triggers a Google event update.
model GoogleEventMapping {
  /// FK to CalendarEvent. Cascade delete.
  eventId           String
  /// FK to CompanyFunction. Restrict delete.
  companyFunctionId String
  /// Google event ID within the target Google Calendar.
  googleEventId     String
  /// Google Calendar ID where this event lives.
  googleCalendarId  String
  /// Deterministic hash of event content. Change triggers a Google Calendar update.
  contentHash       String
  lastSyncedAt      DateTime

  /// The calendar event this mapping belongs to.
  event           CalendarEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// The company function this mapping is for.
  companyFunction CompanyFunction @relation(fields: [companyFunctionId], references: [id], onDelete: Restrict)

  @@id([eventId, companyFunctionId])
  @@index([googleCalendarId])
  @@map("google_event_mappings")
}

// ─── Calendar Catalog ─────────────────────────────────────────────────────────

/// Configurable calendar domain catalog. type discriminator: "eventType". value is the immutable machine key (e.g. "KICKOFF"); label is the editable display name.
model CalendarCatalogItem {
  id        String   @id @default(uuid())
  /// Discriminator (e.g. "eventType"). Defines which dropdown/field this item populates.
  type      String
  /// Immutable machine key (e.g. "KICKOFF"). Used as stored value in event.type.
  value     String
  /// Human-readable display label (editable without changing the value).
  label     String
  /// Display order within the type group.
  order     Int      @default(0)
  /// Soft-delete flag. Inactive items are hidden from pickers.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, value])
  @@index([type, isActive])
  @@map("calendar_catalog_items")
}

// ─── Phase Catalog ──────────────────────────────────────────────────────────

/// Unified, ordered production/calendar phase catalog. Replaces the parallel, non-comparable
/// CollectionCatalogItem(type=progress) and CalendarCatalogItem(type=eventType) domains so a
/// row's production state and a calendar event's milestone can be compared on the same axis.
model Phase {
  id        String   @id @default(uuid())
  /// Immutable machine key. Used as the stored FK target.
  value     String   @unique
  /// Human-readable display label (editable without changing the value).
  label     String
  /// User-visible short code (e.g. "01"), for compatibility with existing UI codes.
  code      String?
  /// Display order. Single source of truth for phase ordering (no hardcoded frontend constants).
  order     Int      @default(0)
  /// Soft-delete flag. Inactive phases are hidden from pickers.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Rows currently in this phase.
  collectionLayoutRows       CollectionLayoutRow[]
  /// Calendar events tagged with this phase.
  calendarEvents             CalendarEvent[]
  /// Milestone template items tagged with this phase.
  milestoneTemplateItems     MilestoneTemplateItem[]
  /// Revision-type catalog items whose expected minimum phase is this one.
  expectedMinForCatalogItems CollectionCatalogItem[]
  /// Row history entries recording a transition into this phase.
  rowPhaseHistory            CollectionRowPhaseHistory[]

  @@index([isActive])
  @@map("phases")
}

/// In-app notification delivered to a user. Rendered in the notification bell and optionally linked to a resource.
model Notification {
  id        String               @id @default(uuid())
  /// FK to User (recipient). Cascade delete.
  userId    String
  /// The user this notification is for.
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Category: SYSTEM | CALENDAR | USER_ACTION | WORKFLOW.
  category  NotificationCategory
  title     String
  message   String
  /// Optional deep-link URL to the relevant resource.
  link      String?
  /// Optional structured payload for custom rendering.
  data      Json?
  /// False until the user opens/acknowledges the notification.
  isRead    Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// Per-user, per-category notification preference. When enabled=false, notifications in that category are suppressed.
model NotificationPreference {
  id        String               @id @default(uuid())
  /// FK to User. Cascade delete.
  userId    String
  /// The user this preference applies to.
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Notification category: SYSTEM | CALENDAR | USER_ACTION | WORKFLOW.
  category  NotificationCategory
  /// When false, notifications in this category are suppressed for the user.
  enabled   Boolean              @default(true)
  updatedAt DateTime             @updatedAt

  @@unique([userId, category])
  @@index([userId])
  @@map("notification_preferences")
}

/// State side-effect definition on a MilestoneTemplateItem. Applied to generated CalendarEventStateEffect records when a template is instantiated.
model MilestoneTemplateStateEffect {
  id                   String          @id @default(uuid())
  /// FK to MilestoneTemplateItem. Cascade delete.
  templateItemId       String
  /// Type of state change: LOCK_COLLECTION_LAYOUT | UNLOCK_COLLECTION_LAYOUT.
  effectType           StateEffectType
  /// Entity type the effect targets (e.g. "collection_layout").
  targetEntityType     String
  /// If true, the user must confirm before the effect is applied.
  requiresConfirmation Boolean         @default(true)

  /// The template item that owns this state effect definition.
  templateItem MilestoneTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)

  @@index([templateItemId])
  @@map("milestone_template_state_effects")
}

/// Live state side-effect attached to a CalendarEvent targeting a specific entity instance. Tracks executions and rollbacks.
model CalendarEventStateEffect {
  id                   String          @id @default(uuid())
  /// FK to CalendarEvent. Cascade delete.
  eventId              String
  /// Type of state change: LOCK_COLLECTION_LAYOUT | UNLOCK_COLLECTION_LAYOUT.
  effectType           StateEffectType
  /// Entity type the effect targets (e.g. "collection_layout").
  targetEntityType     String
  /// ID of the specific entity instance to apply the effect to.
  targetEntityId       String
  /// If true, the user must confirm before the effect is applied.
  requiresConfirmation Boolean

  /// The calendar event that owns this state effect.
  event      CalendarEvent                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// Execution records tracking when this effect was applied and rolled back.
  executions CalendarEventEffectExecution[]

  @@index([eventId])
  @@index([targetEntityType, targetEntityId])
  @@map("calendar_event_state_effects")
}

/// Execution record for a CalendarEventStateEffect. Stores the pre-application state snapshot to enable rollback.
model CalendarEventEffectExecution {
  id                    String    @id @default(uuid())
  /// FK to CalendarEventStateEffect. Cascade delete.
  effectId              String
  /// FK to CalendarEvent. Cascade delete.
  eventId               String
  appliedAt             DateTime  @default(now())
  /// FK to User who applied the effect. Restrict delete.
  appliedByUserId       String
  /// JSON snapshot of the entity state before the effect was applied (used for rollback).
  previousStateSnapshot Json
  /// Timestamp when the effect was rolled back. Null if still active.
  rolledBackAt          DateTime?
  /// FK to User who rolled back the effect. SetNull if user is deleted.
  rolledBackByUserId    String?

  /// The state effect this execution belongs to.
  effect       CalendarEventStateEffect @relation(fields: [effectId], references: [id], onDelete: Cascade)
  /// The calendar event associated with this execution.
  event        CalendarEvent            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  /// The user who applied the effect.
  appliedBy    User                     @relation("EffectApplier", fields: [appliedByUserId], references: [id], onDelete: Restrict)
  /// The user who rolled back the effect, if any.
  rolledBackBy User?                    @relation("EffectRollbacker", fields: [rolledBackByUserId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([effectId])
  @@map("calendar_event_effect_executions")
}

/// Entity type an EditLock can target.
enum LockEntityType {
  SEASON_CALENDAR
  COLLECTION_LAYOUT
}

/// Session-scoped edit lock preventing concurrent editing of a SeasonCalendar or CollectionLayout
/// while a user has the planning wizard open. Distinct from CalendarEventStateEffect (a domain-level
/// lock triggered by milestone events) — this is a UI-session lock, released on completion/unmount
/// or expired via a fixed TTL (no renewal/heartbeat).
model EditLock {
  id             String         @id @default(uuid())
  entityType     LockEntityType
  entityId       String
  /// FK to User. Cascade delete — a lock has no meaning once its owner is gone.
  lockedByUserId String
  /// The user holding this lock.
  lockedByUser   User           @relation(fields: [lockedByUserId], references: [id], onDelete: Cascade)
  lockedAt       DateTime       @default(now())
  /// Hard cutoff — no renewal. Past this instant the lock is considered stale and ignorable.
  expiresAt      DateTime

  @@unique([entityType, entityId])
  @@map("edit_locks")
}

/// Country entity used as the scope for public holiday definitions and vendor closure periods.
model HolidayCountry {
  /// ISO 3166-1 alpha-2 country code (PK).
  code   String  @id
  name   String
  /// When false, this country is excluded from holiday sync and closure calculations.
  active Boolean @default(true)

  /// Public holidays defined for this country.
  holidays       Holiday[]
  /// Vendor closure periods scoped to this country.
  vendorClosures VendorClosurePeriod[]

  @@map("holiday_countries")
}

/// Public holiday for a country. Used to auto-suggest vendor closure periods.
model Holiday {
  id          String   @id @default(uuid())
  /// FK to HolidayCountry. Restrict delete.
  countryCode String
  /// Holiday name in the local language.
  name        String
  /// Holiday name in English (optional).
  nameEn      String?
  /// Start date of the holiday (date only, no time).
  startDate   DateTime @db.Date
  /// End date of the holiday (date only, no time). Equal to startDate for single-day holidays.
  endDate     DateTime @db.Date
  /// True for religious holidays (e.g. Christmas, Easter).
  isReligious Boolean  @default(false)
  /// Data source identifier (e.g. "nager.date", "manual").
  source      String?

  /// The country this holiday belongs to.
  country         HolidayCountry        @relation(fields: [countryCode], references: [code], onDelete: Restrict)
  /// Vendor closure periods that were derived from this holiday.
  vendorOverrides VendorClosurePeriod[] @relation("ClosureSourceHoliday")

  @@unique([countryCode, name, startDate])
  @@index([countryCode, startDate, endDate])
  @@map("holidays")
}

/// Vendor unavailability or open-override period for a given season. Can be auto-suggested from a Holiday or created manually.
model VendorClosurePeriod {
  id                String             @id @default(uuid())
  /// FK to Vendor. Cascade delete.
  vendorId          String
  /// FK to Season. Cascade delete.
  seasonId          String
  /// FK to HolidayCountry (optional). Provides context for the closure reason. SetNull if country is deleted.
  countryCode       String?
  /// Human-readable name for this period (e.g. "Chinese New Year 2026").
  name              String
  /// Start date of the period (date only, no time).
  startDate         DateTime           @db.Date
  /// End date of the period (date only, no time).
  endDate           DateTime           @db.Date
  /// Type: CLOSURE (vendor unavailable) or OPEN (override — vendor is open despite a holiday).
  type              VendorOverrideType @default(CLOSURE)
  /// FK to Holiday that originated this period (optional). SetNull if holiday is deleted.
  sourceHolidayId   String?
  /// Timestamp when a user confirmed this period. Null = pending confirmation.
  confirmedAt       DateTime?
  /// FK to User who confirmed this period. SetNull if user is deleted.
  confirmedByUserId String?
  notes             String?            @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// The vendor this closure period applies to.
  vendor        Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  /// The season this closure period is scoped to.
  season        Season          @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  /// The country associated with this closure period.
  country       HolidayCountry? @relation(fields: [countryCode], references: [code], onDelete: SetNull)
  /// The public holiday that suggested this closure period.
  sourceHoliday Holiday?        @relation("ClosureSourceHoliday", fields: [sourceHolidayId], references: [id], onDelete: SetNull)
  /// The user who confirmed this period.
  confirmedBy   User?           @relation("ClosureConfirmer", fields: [confirmedByUserId], references: [id], onDelete: SetNull)

  @@index([vendorId, seasonId])
  @@index([seasonId, startDate, endDate])
  @@map("vendor_closure_periods")
}
