// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // sqlite = local dev | postgresql = production (patched by Dockerfile before prisma generate)
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  admin
  editor
  viewer
}

enum Provider {
  LOCAL
  LDAP
  OIDC
}

enum TokenType {
  RESET
  VERIFY
}

// Models
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  username          String    @unique
  firstName         String    @default("")
  lastName          String    @default("")
  role              Role
  isActive          Boolean   @default(true)
  pendingApproval   Boolean   @default(false)
  locale            String    @default("it-IT")
  timezone          String    @default("Europe/Rome")
  tokenVersion      Int       @default(0)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  loginCount        Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  identities Identity[]
  auditLogs  AuditLog[]
  tokens     UserToken[]
  sectionAccess UserSectionAccess[]
  grantedPermissions UserGrantedPermission[]
  permissionsGrantedBy UserGrantedPermission[] @relation("PermissionGranter")
  permissionAudits PermissionAudit[]
  permissionAuditsAsActor PermissionAudit[] @relation("PermissionAuditActor")

  @@map("users")
}

model Identity {
  id         String   @id @default(uuid())
  userId     String
  provider   Provider
  providerId String
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  localCredential LocalCredential?

  @@unique([provider, providerId])
  @@map("identities")
}

model LocalCredential {
  id           String   @id @default(uuid())
  identityId   String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  identity Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@map("local_credentials")
}

model AppConfig {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  isEncrypted Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("app_configs")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  // Sostituisce userId (più chiaro)
  action     String   // SCREAMING_SNAKE_CASE (es. USER_CREATE)
  targetType String   // Tipo risorsa (User, Config, Auth)
  targetId   String?  // ID risorsa target (opzionale)
  result     String   // SUCCESS o FAILURE (esplicito)
  metadata   Json?    // Dati redatti
  traceId    String?
  ip         String?  // Rinomina da ipAddress per brevità
  createdAt  DateTime @default(now()) // Rinomina da timestamp
  
  // Relations
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}

model UserToken {
  id         String    @id @default(uuid())
  userId     String
  type       TokenType
  tokenHash  String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, tokenHash])
  @@index([userId, type])
  @@map("user_tokens")
}

model FileObject {
  id             String   @id @default(uuid())
  bucket         String
  key            String
  originalName   String
  size           Int
  contentType    String
  checksumSha256 String
  createdBy      String
  cleanupStatus  String   @default("PENDING")  // PENDING | SUCCESS | FAILED
  cleanupAttempts Int    @default(0)
  lastCleanupAt  DateTime?
  createdAt      DateTime @default(now())

  @@unique([bucket, key])
  @@index([bucket, key])
  @@index([createdAt])
  @@index([createdBy])
  @@index([cleanupStatus])
  @@map("file_objects")
}

model UserSectionAccess {
  id        String   @id @default(uuid())
  userId    String
  section   String   // 'settings' | 'maintenance'
  enabled   Boolean  // true=allow, false=deny
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, section])
  @@index([userId, section])
  @@map("user_section_access")
}

model Brand {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricingParameterSets PricingParameterSet[]
  collectionLayouts    CollectionLayout[]

  @@index([name])
  @@index([isActive, name])
  @@map("brands")
}

model Season {
  id        String   @id @default(uuid())
  code      String
  year      Int
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricingParameterSets PricingParameterSet[]
  collectionLayouts    CollectionLayout[]

  @@unique([code, year])
  @@index([code, year])
  @@map("seasons")
}

model UserPreference {
  userId       String   @id
  lastBrandId  String?
  lastSeasonId String?
  pinnedContexts Json?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([lastBrandId])
  @@map("user_preferences")
}

/**
 * Permissions espliciti concessi agli utenti
 * Integra le permissions di base definite dal ruolo
 * Supporta grant temporanei e revoca granulare
 */
model UserGrantedPermission {
  id        String   @id @default(uuid())
  userId    String
  permission String   // Formato 'resource:action' (es. 'brands:create')
  grantedBy String?  // ID dell'admin che ha concesso (nullable per onDelete: SetNull)
  reason    String?  // Motivo della concessione (audit)
  expiresAt DateTime? // Null = no expiration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser User? @relation("PermissionGranter", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, permission])
  @@index([userId])
  @@index([permission])
  @@index([expiresAt])
  @@map("user_granted_permissions")
}

/**
 * Audit trail per cambamenti di permissions
 * Registra tutte le operazioni di grant, revoke, e cambamenti di ruolo
 */
model PermissionAudit {
  id         String   @id @default(uuid())
  actorId    String?  // Admin che ha effettuato l'azione (nullable per onDelete: SetNull)
  action     String   // 'GRANT' | 'REVOKE' | 'ROLE_CHANGE' | 'PERMISSION_EXPIRED'
  userId     String   // Utente interessato
  permission String?  // Permission interessata (null per ROLE_CHANGE)
  oldRole    Role?    // Ruolo precedente (per ROLE_CHANGE)
  newRole    Role?    // Nuovo ruolo (per ROLE_CHANGE)
  reason     String?  // Motivo dell'azione
  createdAt  DateTime @default(now())

  actor User? @relation("PermissionAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([action, createdAt])
  @@index([userId])
  @@index([actorId])
  @@map("permission_audits")
}

/**
 * Set di parametri di pricing per brand+season
 * Ogni brand+season può avere più varianti (es. Pelle, Non Pelle, Tunisia)
 * I parametri guidano la calcolatrice di costi e prezzi
 */
model PricingParameterSet {
  id                     String   @id @default(uuid())
  brandId                String
  seasonId               String
  name                   String   // es. "Pelle", "Non Pelle", "Tunisia"
  purchaseCurrency       String   @default("USD")
  sellingCurrency        String   @default("EUR")
  qualityControlPercent  Float
  transportInsuranceCost Float
  duty                   Float
  exchangeRate           Float
  italyAccessoryCosts    Float
  tools                  Float
  retailMultiplier       Float
  optimalMargin          Float
  isDefault              Boolean  @default(false)
  orderIndex             Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  brand  Brand  @relation(fields: [brandId], references: [id])
  season Season @relation(fields: [seasonId], references: [id])
  collectionLayoutRows CollectionLayoutRow[]

  @@unique([brandId, seasonId, name])
  @@index([brandId, seasonId])
  @@map("pricing_parameter_sets")
}

/**
 * Collection Layout — unico per brand+stagione
 * Rappresenta l'elenco delle linee che compongono una collezione stagionale
 */
model CollectionLayout {
  id            String   @id @default(uuid())
  brandId       String
  seasonId      String
  skuBudget     Int?
  hiddenColumns Json?    // String[] — colonne nascoste, null = tutte visibili
  brand         Brand    @relation(fields: [brandId], references: [id])
  season        Season   @relation(fields: [seasonId], references: [id])
  groups        CollectionGroup[]
  rows          CollectionLayoutRow[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([brandId, seasonId])
  @@index([brandId, seasonId])
  @@map("collection_layouts")
}

/**
 * Gruppo di righe all'interno di un Collection Layout
 * Es. "Collezione Uomo", "Collezione Donna", "Special Edition"
 */
model CollectionGroup {
  id                 String           @id @default(uuid())
  collectionLayoutId String
  collectionLayout   CollectionLayout @relation(fields: [collectionLayoutId], references: [id], onDelete: Cascade)
  name               String
  order              Int              @default(0)
  skuBudget          Int?
  rows               CollectionLayoutRow[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([collectionLayoutId])
  @@map("collection_groups")
}

/**
 * Singola riga del Collection Layout
 * Rappresenta una linea/stile all'interno di una collezione
 */
model CollectionLayoutRow {
  id                     String                @id @default(uuid())
  collectionLayoutId     String
  collectionLayout       CollectionLayout      @relation(fields: [collectionLayoutId], references: [id], onDelete: Cascade)
  groupId                String
  group                  CollectionGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  order                  Int                   @default(0)

  // Required fields
  gender                 String                // MAN | WOMAN
  supplier               String
  line                   String
  status                 String                // CARRY_OVER | NEW
  skuForecast            Int
  qtyForecast            Int
  productCategory        String

  // Optional — identification/progress
  strategy               String?               // CORE | INNOVATION
  styleStatus            String?               // CARRY_OVER | NEW (STYLE STATUS)
  progress               String?               // 01–06 stages
  designer               String?
  pictureUrl             String?

  // Optional — notes
  styleNotes             String?
  materialNotes          String?
  colorNotes             String?
  priceNotes             String?
  toolingNotes           String?

  // Optional — pricing
  dutyCategory           String?               // PELLE | SINTETICO_TESSUTO
  pricingParameterSetId  String?
  pricingParameterSet    PricingParameterSet?  @relation(fields: [pricingParameterSetId], references: [id], onDelete: SetNull)
  retailTargetPrice      Float?
  buyingTargetPrice      Float?
  supplierFirstQuotation Float?
  toolingQuotation       Float?

  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([collectionLayoutId])
  @@index([groupId])
  @@map("collection_layout_rows")
}
