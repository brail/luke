{
  "name": "@luke/monorepo",
  "version": "1.10.0-dev.0",
  "private": true,
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "deps:latest": "pnpm update --latest",
    "sync-version": "node scripts/sync-version.js",
    "sync-version:check": "node scripts/sync-version.js --check",
    "db:seed": "pnpm --filter @luke/api db:seed",
    "codemod:eliminate-urls": "tsx tools/codemods/eliminate-hardcoded-urls.ts",
    "codemod:check-urls": "tsx tools/codemods/eliminate-hardcoded-urls.ts --dry-run",
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:bump": "git-cliff --bump -o CHANGELOG.md",
    "changelog:tag": "git-cliff -o CHANGELOG.md",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-import": "^2.32.0",
    "git-cliff": "^2.13.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.5",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  }
}
