{
  "name": "@luke/monorepo",
  "version": "1.8.0",
  "private": true,
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "deps:latest": "pnpm update --latest",
    "prepare": "husky install",
    "sync-version": "node scripts/sync-version.js",
    "sync-version:check": "node scripts/sync-version.js --check",
    "db:seed": "pnpm --filter @luke/api db:seed",
    "codemod:eliminate-urls": "tsx tools/codemods/eliminate-hardcoded-urls.ts",
    "codemod:check-urls": "tsx tools/codemods/eliminate-hardcoded-urls.ts --dry-run"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.37.0",
    "eslint-config-next": "^15.5.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "ts-morph": "^27.0.0",
    "tsx": "^4.19.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  }
}
