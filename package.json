{
  "name": "@luke/monorepo",
  "version": "1.10.0-dev.0",
  "private": true,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "deps:latest": "pnpm update --latest",
    "sync-version": "node scripts/sync-version.js",
    "sync-version:check": "node scripts/sync-version.js --check",
    "db:seed": "pnpm --filter @luke/api db:seed",
    "codemod:eliminate-urls": "tsx tools/codemods/eliminate-hardcoded-urls.ts",
    "codemod:check-urls": "tsx tools/codemods/eliminate-hardcoded-urls.ts --dry-run",
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:bump": "git-cliff --bump -o CHANGELOG.md",
    "changelog:tag": "git-cliff -o CHANGELOG.md",
    "prepare": "husky",
    "security:sast": "semgrep scan --config .semgrep/rules/mutation-requires-permission.yml; semgrep scan --config p/typescript --config p/nextjs --config p/nodejs --config p/react --config p/sql-injection --config .semgrep/rules/no-console.yml --config .semgrep/rules/raw-query-guard.yml --config .semgrep/rules/no-direct-env.yml --error",
    "security:secrets": "gitleaks detect --source .",
    "security:deps": "osv-scanner scan -r .",
    "security": "pnpm security:sast && pnpm security:secrets && pnpm security:deps"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "globals": "^16.4.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^9.38.0",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-luke": "workspace:*",
    "git-cliff": "^2.13.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.5",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  }
}
