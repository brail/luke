if ! command -v gitleaks >/dev/null 2>&1; then
  echo "❌ gitleaks non trovato nel PATH. Installa con: brew install gitleaks" >&2
  exit 1
fi
if ! command -v semgrep >/dev/null 2>&1; then
  echo "❌ semgrep non trovato nel PATH. Installa con: brew install semgrep (o pipx install semgrep)" >&2
  exit 1
fi

gitleaks protect --staged || exit 1

# Solo regole ERROR-tier per velocità (<5s): community ruleset e la regola
# WARNING (luke-mutation-requires-permission) girano in CI, non qui.
semgrep scan --config .semgrep/rules/no-console.yml --config .semgrep/rules/raw-query-guard.yml --config .semgrep/rules/no-direct-env.yml --error --baseline-commit HEAD
