# ─────────────────────────────────────────────────────────────────────────────
# Luke — Production Environment Variables
# Copy this file to .env and fill in all values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# Public hostname (without scheme) — used by docker-compose for NEXTAUTH_URL
# and the NEXT_PUBLIC_API_URL build-arg.
PUBLIC_HOSTNAME=luke.febos.local

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Password for the 'luke' PostgreSQL user created by the postgres container.
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_strong_password

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Random secret used to sign/encrypt NextAuth session cookies.
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_strong_secret

# ─────────────────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────────────────
#
# API JWT secret & NextAuth secret are DERIVED from the master key stored in
# the 'api_data' Docker volume at /root/.luke/secret.key.
# The master key is auto-generated on first start. Back it up after first run:
#
#   docker compose cp api:/root/.luke/secret.key ./secret.key.backup
#
# Storage for uploaded files also lives in the same volume (/root/.luke/storage/).
#
# CORS is intentionally disabled for direct browser → API requests.
# All API calls are proxied through the Next.js container (rewrites in next.config.js).
